<!-- ═══════════════════ AUTH MODAL ═══════════════════ -->
<div class="modal-overlay" id="authModalOverlay">
<div class="modal auth-modal" id="authModal">
    <div class="modal-body">
    <button class="modal-close" id="authModalClose" style="position:static;float:right;background:var(--bg3);border:1px solid var(--border2);">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
    </button>
    <div style="clear:both;"></div>
    <div class="auth-tabs">
        <button class="auth-tab active" id="tabLogin">Login</button>
        <button class="auth-tab" id="tabRegister">Register</button>
    </div>
    <div id="loginForm">
        <div class="auth-title">Welcome!</div>
        <div class="auth-subtitle">Login to your account</div>
        <div class="form-group">
        <label class="form-label">EMAIL</label>
        <input class="form-input" type="email" placeholder="nama@email.com" id="loginEmail">
        </div>
        <div class="form-group">
        <label class="form-label">PASSWORD</label>
        <input class="form-input" type="password" placeholder="••••••••" id="loginPassword">
        </div>
        <div style="text-align:right;margin-top:-4px;margin-bottom:8px">
          <a id="forgotPasswordLink" style="font-size:12px;color:var(--text1);cursor:pointer;">Forgot Password?</a>
        </div>
        <button class="btn-auth" id="btnAuthLogin">Login</button>
        <div class="auth-footer-text">Don't have an account? <a data-switch-tab="register">Register now</a></div>
    </div>
    <div id="registerForm" style="display:none;">
        <div class="auth-title">Create new account</div>
        <div class="auth-subtitle">Join thousands of users</div>
        <div class="form-group">
            <label class="form-label">USERNAME</label>
            <input class="form-input" type="text" placeholder="Username Anda" id="regUsername">
        </div>
        <div class="form-group">
            <label class="form-label">EMAIL</label>
            <input class="form-input" type="email" placeholder="nama@email.com" id="regEmail">
        </div>
        <div class="form-group">
            <label class="form-label">PASSWORD</label>
            <input class="form-input" type="password" placeholder="Min. 8 karakter" id="regPassword">
        </div>
        <div class="form-group">
            <label class="form-label">CONFIRM PASSWORD</label>
            <input class="form-input" type="password" placeholder="Min. 8 karakter" id="regConfirmPassword">
        </div>
        <div class="form-group">
            <input type="checkbox" id="regTerms" name="regTerms">
            <label for="regTerms">I agree to the <a class="syaratKet" href="#">terms and conditions</a></label>
        </div> 
        <button class="btn-auth" id="btnAuthRegister">Create Account</button>
        <div class="auth-footer-text">Already have an account? <a data-switch-tab="login">Login</a></div>
    </div>
    <div id="forgotForm" style="display:none;">
        <div class="auth-title">Reset Password</div>
        <div class="auth-subtitle">Enter your email to receive a reset link</div>
        <div class="form-group">
            <label class="form-label">EMAIL</label>
            <input class="form-input" type="email" placeholder="nama@email.com" id="forgotEmail">
        </div>
        <button class="btn-auth" id="btnAuthForgot">Send Reset Link</button>
        <div class="auth-footer-text">
            <a id="backToLogin" style="cursor:pointer">◀ Back to Login</a>
        </div>
    </div>
    </div>
</div>
</div>
