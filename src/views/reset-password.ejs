<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>GINYUU — Reset Password</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/assets/css/landing.css"/>
  <script src="/assets/js/navbar.js" type="module"></script>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{--bg:#0a0a0a;--bg2:#111111;--bg3:#181818;--bg4:#222222;--border:#2a2a2a;--border2:#333333;--text:#f0f0f0;--text2:#999999;--text3:#555555;--accent:#ffffff;--accent2:#e0e0e0;--danger:#ff4444;--success:#22c55e;--shadow:0 20px 60px rgba(0,0,0,.6)}
    body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px}
    h1,h2,h3{font-family:'Syne',sans-serif}
    .reset-card{background:var(--bg2);border:1px solid var(--border2);border-radius:20px;max-width:440px;width:100%;padding:40px;box-shadow:var(--shadow)}
    .reset-card h1{font-size:22px;font-weight:800;text-align:center;margin-bottom:4px}
    .reset-card .subtitle{font-size:14px;color:var(--text2);text-align:center;margin-bottom:28px}
    .form-group{display:flex;flex-direction:column;gap:6px;margin-bottom:16px}
    .form-label{font-size:12px;font-weight:500;color:var(--text2);letter-spacing:0.02em}
    .form-input{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px 12px;font-size:14px;color:var(--text);font-family:'DM Sans',sans-serif;outline:none;transition:border-color .25s;width:100%}
    .form-input:focus{border-color:var(--border2)}
    .form-input::placeholder{color:var(--text3)}
    .btn-auth{width:100%;padding:12px;border-radius:10px;border:none;background:var(--accent);color:var(--bg);font-size:14px;font-weight:700;cursor:pointer;transition:all .25s;font-family:'DM Sans',sans-serif;margin-top:4px}
    .btn-auth:hover{background:var(--accent2)}
    .btn-auth:disabled{opacity:.4;cursor:not-allowed}
    .error-msg{text-align:center;padding:16px;background:rgba(255,68,68,0.08);border:1px solid rgba(255,68,68,0.2);border-radius:10px;margin-bottom:16px}
    .error-msg p{font-size:14px;color:var(--danger);margin-bottom:4px}
    .error-msg .hint{font-size:12px;color:var(--text3)}
    .success-msg{text-align:center;padding:24px 0}
    .success-msg .icon{font-size:48px;margin-bottom:12px}
    .success-msg h2{font-size:18px;font-weight:700;margin-bottom:6px}
    .success-msg p{font-size:14px;color:var(--text2);margin-bottom:20px}
    .status-text{font-size:12px;color:var(--text3);text-align:center;margin-top:8px}
    .status-text.error{color:var(--danger)}
    .status-text.success{color:var(--success)}
    .spinner{display:inline-block;width:16px;height:16px;border:2px solid var(--bg);border-top-color:transparent;border-radius:50%;animation:spin .6s linear infinite;vertical-align:middle;margin-right:6px}
    @keyframes spin{to{transform:rotate(360deg)}}
    .logo{text-align:center;margin-bottom:20px;font-family:'Syne',sans-serif;font-size:20px;font-weight:800;color:var(--text)}
  </style>
</head>
<body>
  <div class="reset-card">
    <div class="logo">GINYUU</div>

    <% if (!token) { %>
      <div class="error-msg">
        <p>Invalid reset link</p>
        <div class="hint">No reset token found in the URL. Please request a new password reset.</div>
      </div>
      <a href="/" style="display:block;text-align:center;color:var(--text2);font-size:14px">← Back to Home</a>
    <% } else { %>
      <h1>Reset Password</h1>
      <div class="subtitle">Enter your new password below</div>

      <div id="resetForm">
        <div class="form-group">
          <label class="form-label">NEW PASSWORD</label>
          <input class="form-input" type="password" id="resetPassword" placeholder="Min. 8 characters" autocomplete="new-password"/>
        </div>
        <div class="form-group">
          <label class="form-label">CONFIRM PASSWORD</label>
          <input class="form-input" type="password" id="resetConfirmPassword" placeholder="Repeat your password" autocomplete="new-password"/>
        </div>
        <button class="btn-auth" id="btnResetPassword">Reset Password</button>
        <div id="resetStatus" class="status-text"></div>
      </div>

      <div id="resetSuccess" style="display:none">
        <div class="success-msg">
          <div class="icon">✓</div>
          <h2>Password Reset Successfully</h2>
          <p>Your password has been updated. You can now login with your new password.</p>
          <a href="/" class="btn-auth" style="display:inline-block;text-decoration:none;padding:10px 28px;width:auto">Go to Login</a>
        </div>
      </div>
    <% } %>
  </div>

  <script>
    document.getElementById('btnResetPassword')?.addEventListener('click', async () => {
      const password = document.getElementById('resetPassword').value;
      const confirm = document.getElementById('resetConfirmPassword').value;
      const status = document.getElementById('resetStatus');
      const btn = document.getElementById('btnResetPassword');

      if (!password || !confirm) {
        status.textContent = 'Please fill all fields';
        status.className = 'status-text error';
        return;
      }
      if (password.length < 8) {
        status.textContent = 'Password must be at least 8 characters';
        status.className = 'status-text error';
        return;
      }
      if (password !== confirm) {
        status.textContent = 'Passwords do not match';
        status.className = 'status-text error';
        return;
      }

      btn.disabled = true;
      const originalText = 'Reset Password';
      btn.innerHTML = '<span class="spinner"></span>Resetting...';
      status.textContent = '';
      status.className = 'status-text';

      try {
        const res = await fetch('/api/auth/reset-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token: '<%= token %>', password })
        });
        const data = await res.json();

        if (data.status === 'success') {
          document.getElementById('resetForm').style.display = 'none';
          document.getElementById('resetSuccess').style.display = 'block';
        } else {
          status.textContent = data.message || 'Failed to reset password';
          status.className = 'status-text error';
          btn.disabled = false;
          btn.textContent = originalText;
        }
      } catch (err) {
        status.textContent = 'An error occurred. Please try again.';
        status.className = 'status-text error';
        btn.disabled = false;
        btn.textContent = originalText;
      }
    });
  </script>
</body>
</html>
