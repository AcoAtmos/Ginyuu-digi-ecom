<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Checkout — DIGISTORE</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/css/checkout.css">
<script>window.PUBLIC_URL = '<%= PUBLIC_URL %>';</script>
<script src="/assets/js/checkout.js" type="module"></script>
</head>
<body>

<!-- ═══════ NAVBAR ═══════ -->
<nav class="navbar">
  <button class="nav-back" onclick="history.back()">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="15 18 9 12 15 6"/>
    </svg>
    Kembali
  </button>

  <a href="/" class="nav-brand">DIGI<span>STORE</span></a>
  <div class="nav-spacer"></div>
  <div class="nav-secure">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
      <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
      <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
    </svg>
    Pembayaran Aman
  </div>
</nav>

<!-- ═══════ PROGRESS ═══════ -->
<div class="progress-wrap">
  <div class="progress-steps">
    <div class="progress-step done" id="step1">
      <div class="step-num">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <span class="step-label">Keranjang</span>
    </div>
    <div class="progress-line done"></div>
    <div class="progress-step active" id="step2">
      <div class="step-num">2</div>
      <span class="step-label">Checkout</span>
    </div>
    <div class="progress-line"></div>
    <div class="progress-step" id="step3">
      <div class="step-num">3</div>
      <span class="step-label">Konfirmasi</span>
    </div>
  </div>
</div>

<!-- ═══════ MAIN LAYOUT ═══════ -->
<div class="checkout-layout">

  <!-- ══════ LEFT: FORM ══════ -->
  <div class="form-col">

    <!-- SECTION 1: INFO -->
    <div class="card" style="animation-delay:.05s">
      <div class="card-header">
        <div class="card-title">
          <div class="card-title-num">1</div>
          Informasi Akun
        </div>
        <div id="loginStatusBadge"></div>
      </div>
      <div class="card-body">

        <!-- Logged-in banner -->
        <div class="logged-banner" id="loggedBanner" style="display:none">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          <span>Login sebagai <strong id="loggedName"></strong>. Data Anda terisi otomatis.</span>
        </div>

        <!-- Username (guest only) -->
        <div class="form-row single guest-only" style="margin-bottom:14px">
          <div class="form-group">
            <label class="form-label">Username <span class="req">*</span></label>
            <div class="input-wrap">
              <input type="text" class="form-input" id="username" placeholder="JohnDoe" autocomplete="username">
            </div>
            <span class="form-error" id="usernameErr">Username wajib diisi</span>
          </div>
        </div>

        <!-- Email (guest only) -->
        <div class="form-row single guest-only" style="margin-bottom:14px">
          <div class="form-group">
            <label class="form-label">Email <span class="req">*</span></label>
            <div class="input-wrap">
              <input type="email" class="form-input" id="email" placeholder="nama@email.com" autocomplete="email">
            </div>
            <span class="form-error" id="emailErr">Email tidak valid</span>
          </div>
        </div>

        <!-- Phone (optional) -->
        <div id="phoneFieldRow" class="form-row single" style="margin-bottom:14px">
          <div class="form-group">
            <label class="form-label">Phone <span style="color:var(--text3);font-weight:400;font-size:11px">(optional — for WhatsApp confirmation)</span></label>
            <div class="input-wrap">
              <input type="tel" class="form-input" id="phone" placeholder="08123456789" autocomplete="tel">
            </div>
            <span class="form-error" id="phoneErr"></span>
          </div>
        </div>

        <!-- Password (guest only) -->
        <div id="passwordSection">
          <div class="section-divider" style="margin:20px 0 18px"></div>
          <div style="font-size:12px;color:var(--text3);margin-bottom:16px;display:flex;align-items:center;gap:6px;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Buat akun untuk menyimpan riwayat pembelian Anda
          </div>

          <div class="form-row single" style="margin-bottom:14px">
            <div class="form-group">
              <label class="form-label">Password <span class="req">*</span></label>
              <div class="input-wrap">
                <input type="password" class="form-input" id="password" placeholder="Min. 8 karakter" autocomplete="new-password">
                <div class="input-icon clickable" onclick="togglePass('password', this)">
                  <svg id="eyePass" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                </div>
              </div>
              <div class="strength-bar" id="strengthBar">
                <div class="strength-seg" id="seg1"></div>
                <div class="strength-seg" id="seg2"></div>
                <div class="strength-seg" id="seg3"></div>
                <div class="strength-seg" id="seg4"></div>
              </div>
              <div class="strength-label" id="strengthLabel"></div>
              <span class="form-error" id="passwordErr">Password minimal 8 karakter</span>
            </div>
          </div>

          <div class="form-row single" style="margin-bottom:0">
            <div class="form-group">
              <label class="form-label">Konfirmasi Password <span class="req">*</span></label>
              <div class="input-wrap">
                <input type="password" class="form-input" id="confirmPassword" placeholder="Ulangi password" autocomplete="new-password">
                <div class="input-icon clickable" onclick="togglePass('confirmPassword', this)">
                  <svg id="eyeConfirm" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                </div>
              </div>
              <span class="form-error" id="confirmPasswordErr">Password tidak cocok</span>
            </div>
          </div>
        </div>

        <!-- Terms (guest only) -->
        <div class="form-row single guest-only" style="margin-top:16px">
          <div class="form-group" style="display:flex;align-items:flex-start;gap:10px;">
            <input type="checkbox" id="terms" style="margin-top:3px;width:16px;height:16px;cursor:pointer;">
            <label for="terms" style="font-size:13px;color:var(--text2);cursor:pointer;line-height:1.5;">
              I agree to the <a href="#" style="color:var(--primary);text-decoration:underline;">Terms and Conditions</a>
            </label>
          </div>
          <span class="form-error" id="termsErr" style="display:none;margin-top:4px;">You must agree to the terms</span>
        </div>

        <!-- Terms (logged-in) -->
        <div class="form-row single logged-only" style="margin-top:16px;display:none;">
          <div class="form-group" style="display:flex;align-items:flex-start;gap:10px;">
            <input type="checkbox" id="termsLoggedIn" style="margin-top:3px;width:16px;height:16px;cursor:pointer;">
            <label for="termsLoggedIn" style="font-size:13px;color:var(--text2);cursor:pointer;line-height:1.5;">
              I agree to the <a href="#" style="color:var(--primary);text-decoration:underline;">Terms and Conditions</a>
            </label>
          </div>
          <span class="form-error" id="termsLoggedInErr" style="display:none;margin-top:4px;">You must agree to the terms</span>
        </div>

      </div>
    </div>

    <!-- SECTION 2: PAYMENT -->
    <div class="card" style="animation-delay:.12s">
      <div class="card-header">
        <div class="card-title">
          <div class="card-title-num">2</div>
          Metode Pembayaran
        </div>
      </div>
      <div class="card-body">

        <!-- 3 method buttons -->
        <div class="payment-methods">
          <button class="pm-btn" data-method="bank">
            <span class="pm-icon">🏦</span>
            <span class="pm-label">Transfer Bank</span>
          </button>
          <button class="pm-btn" data-method="ewallet">
            <span class="pm-icon">📲</span>
            <span class="pm-label">E-Wallet</span>
          </button>
          <button class="pm-btn" data-method="qris">
            <span class="pm-icon">⬛</span>
            <span class="pm-label">QRIS</span>
          </button>
        </div>

        <!-- BANK sub-options -->
        <div class="payment-sub" id="sub-bank">
          <div class="sub-title">Pilih Bank</div>
          <div class="sub-options">
            <label class="sub-option">
              <input type="radio" name="bank" value="BCA">
              <span class="sub-opt-emoji">🔵</span>
              <div class="sub-opt-text">
                <div class="sub-opt-name">BCA</div>
                <div class="sub-opt-desc">Virtual Account</div>
              </div>
              <div class="check-ring"></div>
            </label>
            <label class="sub-option">
              <input type="radio" name="bank" value="Mandiri">
              <span class="sub-opt-emoji">🟡</span>
              <div class="sub-opt-text">
                <div class="sub-opt-name">Mandiri</div>
                <div class="sub-opt-desc">Virtual Account</div>
              </div>
              <div class="check-ring"></div>
            </label>
            <label class="sub-option">
              <input type="radio" name="bank" value="BNI">
              <span class="sub-opt-emoji">🟠</span>
              <div class="sub-opt-text">
                <div class="sub-opt-name">BNI</div>
                <div class="sub-opt-desc">Virtual Account</div>
              </div>
              <div class="check-ring"></div>
            </label>
            <label class="sub-option">
              <input type="radio" name="bank" value="BRI">
              <span class="sub-opt-emoji">🔵</span>
              <div class="sub-opt-text">
                <div class="sub-opt-name">BRI</div>
                <div class="sub-opt-desc">Virtual Account</div>
              </div>
              <div class="check-ring"></div>
            </label>
          </div>
        </div>

        <!-- E-WALLET sub-options -->
        <div class="payment-sub" id="sub-ewallet">
          <div class="sub-title">Pilih E-Wallet</div>
          <div class="sub-options">
            <label class="sub-option">
              <input type="radio" name="ewallet" value="GoPay">
              <span class="sub-opt-emoji">🟢</span>
              <div class="sub-opt-text">
                <div class="sub-opt-name">GoPay</div>
                <div class="sub-opt-desc">Gojek</div>
              </div>
              <div class="check-ring"></div>
            </label>
            <label class="sub-option">
              <input type="radio" name="ewallet" value="OVO">
              <span class="sub-opt-emoji">🟣</span>
              <div class="sub-opt-text">
                <div class="sub-opt-name">OVO</div>
                <div class="sub-opt-desc">Tokopedia</div>
              </div>
              <div class="check-ring"></div>
            </label>
            <label class="sub-option">
              <input type="radio" name="ewallet" value="DANA">
              <span class="sub-opt-emoji">🔵</span>
              <div class="sub-opt-text">
                <div class="sub-opt-name">DANA</div>
                <div class="sub-opt-desc">Dana.id</div>
              </div>
              <div class="check-ring"></div>
            </label>
            <label class="sub-option">
              <input type="radio" name="ewallet" value="ShopeePay">
              <span class="sub-opt-emoji">🟠</span>
              <div class="sub-opt-text">
                <div class="sub-opt-name">ShopeePay</div>
                <div class="sub-opt-desc">Shopee</div>
              </div>
              <div class="check-ring"></div>
            </label>
          </div>
        </div>

        <!-- QRIS info -->
        <div class="payment-sub" id="sub-qris">
          <div style="
            background: var(--bg3);
            border: 1px dashed var(--border2);
            border-radius: var(--radius);
            padding: 24px;
            text-align: center;
          ">
            <div style="font-size: 48px; margin-bottom: 10px;">⬛</div>
            <div style="font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 6px;">QRIS Universal</div>
            <div style="font-size: 13px; color: var(--text2); line-height: 1.6;">Scan QR Code dengan aplikasi e-wallet apapun. GoPay, OVO, DANA, ShopeePay, dan lainnya.</div>
            <div style="margin-top:12px;font-size:11px;color:var(--text3)">QR Code akan ditampilkan setelah konfirmasi pesanan</div>
          </div>
        </div>

        <span class="form-error" id="paymentErr" style="display:none;margin-top:8px;font-size:12px;">
          Pilih metode pembayaran terlebih dahulu
        </span>

      </div>
    </div>

    <!-- REQ BODY PREVIEW -->
    <div class="card" style="animation-delay:.18s">
      <div class="card-header">
        <div class="card-title">
          <div class="card-title-num" style="font-size:9px;">{ }</div>
          Request Body Preview
        </div>
        <span class="req-method">POST /api/checkout</span>
      </div>
      <div class="card-body" style="padding:0">
        <div class="req-body-wrap" style="margin:0;border:none;border-radius:0">
          <div class="req-body-pre" id="reqBodyPre">
            <!-- Rendered by JS -->
          </div>
        </div>
      </div>
    </div>

  </div><!-- end form-col -->

  <!-- ══════ RIGHT: SUMMARY ══════ -->
  <div class="summary-col">

    <div class="card summary-card" style="animation-delay:.08s">
      <div class="card-header">
        <div class="card-title">Ringkasan Pesanan</div>
        <span style="font-size:13px;color:var(--text3)" id="itemCount">0 produk</span>
      </div>
      <div class="card-body">

        <div class="order-items" id="orderItems"></div>

        <!-- Promo -->
        <div class="promo-wrap">
          <input type="text" class="promo-input" id="promoInput" placeholder="Kode promo…" oninput="updateReqBody()">
          <button class="btn-promo" onclick="applyPromo()">Terapkan</button>
        </div>
        <div class="promo-success" id="promoSuccess">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
          Promo DIGI20 berhasil! Hemat 20%
        </div>

        <!-- Upsell -->
        <div class="upsell-wrap" id="upsellWrap" style="display:none">
          <div class="upsell-header">🎯 Pelengkap Pesanan</div>
          <div class="upsell-items" id="upsellItems"></div>
        </div>

        <!-- Price breakdown -->
        <div class="price-rows" id="priceRows"></div>

        <!-- Submit -->
        <button class="btn-place-order" id="placeOrderBtn">
          <span class="btn-text">Bayar Sekarang</span>
          <div class="spinner"></div>
        </button>
        <div class="secure-note">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          Transaksi dienkripsi & dilindungi SSL
        </div>

      </div>
    </div>

  </div><!-- end summary-col -->
</div>

<!-- ═══════ TOAST ═══════
<div class="toast-container" id="toastContainer"></div> -->

</body>
</html>