<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('header.ejs') %>
</head>
<body>

<!-- TOPBAR -->
<%- include('../partials/navbar') %>

<!-- LAYOUT -->
<div class="layout">

  <!-- SIDEBAR -->
  <%- include('sidebar.ejs') %>

  <!-- MAIN -->
  <main class="main" id="main">
    <!-- PURCHASES SECTION -->
        <!-- SETTINGS SECTION -->
    <div id="section-settings" class="section-content" >
      <div class="breadcrumb">Account <span>/ Settings</span></div>
      <div class="page-header">
        <h1>Settings</h1>
        <p>Customize your preferences and notifications</p>
      </div>
      <div class="settings-stack">
        <div class="settings-section">
          <div class="settings-section-header">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            <div>
              <h3>Notifications</h3>
              <p>Manage how and when we contact you</p>
            </div>
          </div>
          <div class="settings-item">
            <div class="settings-item-icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg></div>
            <div class="settings-item-info">
              <div class="settings-item-title">Email Notifications</div>
              <div class="settings-item-desc">Receive updates about your orders and account</div>
            </div>
            <label class="toggle"><input type="checkbox" checked/><span class="toggle-slider"></span></label>
          </div>
          <div class="settings-item">
            <div class="settings-item-icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg></div>
            <div class="settings-item-info">
              <div class="settings-item-title">Push Notifications</div>
              <div class="settings-item-desc">Browser notifications for flash sales and deals</div>
            </div>
            <label class="toggle"><input type="checkbox"/><span class="toggle-slider"></span></label>
          </div>
          <div class="settings-item">
            <div class="settings-item-icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
            <div class="settings-item-info">
              <div class="settings-item-title">Promotional Emails</div>
              <div class="settings-item-desc">Flash sales, discounts, and new product alerts</div>
            </div>
            <label class="toggle"><input type="checkbox" checked/><span class="toggle-slider"></span></label>
          </div>
          <div class="settings-item">
            <div class="settings-item-icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></div>
            <div class="settings-item-info">
              <div class="settings-item-title">Wishlist Reminders</div>
              <div class="settings-item-desc">Get notified when wishlisted items go on sale</div>
            </div>
            <label class="toggle"><input type="checkbox" checked/><span class="toggle-slider"></span></label>
          </div>
        </div>

        <div class="settings-section">
          <div class="settings-section-header">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06A1.65 1.65 0 0 0 15 19.4a1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9z"/></svg>
            <div>
              <h3>Display & Appearance</h3>
              <p>Personalize your visual experience</p>
            </div>
          </div>
          <div class="settings-item">
            <div class="settings-item-icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg></div>
            <div class="settings-item-info">
              <div class="settings-item-title">Theme</div>
              <div class="settings-item-desc">Choose your preferred color theme</div>
            </div>
            <select class="settings-select" onchange="showToast('Theme preference saved')">
              <option>Dark</option>
              <option>Light</option>
              <option>System</option>
            </select>
          </div>
          <div class="settings-item">
            <div class="settings-item-icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9,22 9,12 15,12 15,22"/></svg></div>
            <div class="settings-item-info">
              <div class="settings-item-title">Language</div>
              <div class="settings-item-desc">Platform display language</div>
            </div>
            <select class="settings-select" onchange="showToast('Language updated')">
              <option>Bahasa Indonesia</option>
              <option>English</option>
            </select>
          </div>
          <div class="settings-item">
            <div class="settings-item-icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg></div>
            <div class="settings-item-info">
              <div class="settings-item-title">Currency Display</div>
              <div class="settings-item-desc">Preferred currency for prices</div>
            </div>
            <select class="settings-select" onchange="showToast('Currency updated')">
              <option>IDR (Rp)</option>
              <option>USD ($)</option>
              <option>SGD (S$)</option>
            </select>
          </div>
        </div>

        <div style="display:flex;justify-content:flex-end">
          <button class="btn btn-primary" onclick="showToast('All settings saved ✓')">Save Preferences</button>
        </div>
      </div>
    </div>
  </main>
</div> 

</body>
</html>