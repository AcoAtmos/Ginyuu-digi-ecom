<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('header.ejs') %>
</head>
<body>

<!-- TOPBAR -->
<%- include('../partials/navbar') %>

<!-- LAYOUT -->
<div class="layout">

  <!-- SIDEBAR -->
  <%- include('sidebar.ejs') %>

  <!-- MAIN -->
  <main class="main" id="main">
    <!-- SECURITY SECTION -->
    <div id="section-security" class="section-content">
      <div class="breadcrumb">Account <span>/ Security</span></div>
      <div class="page-header">
        <h1>Security</h1>
        <p>Manage your password, authentication, and active sessions</p>
      </div>
      <div class="security-stack">
        <div class="security-card">
          <div class="security-card-header">
            <div class="security-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div>
            <div>
              <div class="security-title">Password</div>
              <div class="security-subtitle">Last changed 3 months ago</div>
            </div>
            <div class="security-status"><span class="dot-green"></span><span style="color:var(--text2);font-size:12px">Active</span></div>
          </div>
          <div class="form-grid">
            <div class="form-group full">
              <label class="form-label">Current Password</label>
              <input class="form-input" type="password" placeholder="Enter current password" id="curPassword"/>
            </div>
            <div class="form-group">
              <label class="form-label">New Password</label>
              <input class="form-input" type="password" placeholder="New password" id="newPassword"/>
            </div>
            <div class="form-group">
              <label class="form-label">Confirm Password</label>
              <input class="form-input" type="password" placeholder="Confirm new password" id="confirmPassword"/>
            </div>
          </div>
          <div class="form-actions">
            <button class="btn btn-primary" id="btnUpdatePassword">Update Password</button>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

</body>
</html>