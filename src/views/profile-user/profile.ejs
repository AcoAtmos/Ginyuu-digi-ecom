              <div class="form-card">
            <div class="form-card-header">
              <h3>My Email Address</h3>
              <p>Manage linked email addresses</p>
            </div>
            <div class="email-list">
              <div class="email-item">
                <div class="email-icon">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                </div>
                <div class="email-info">
                  <div class="email-addr">alexarawles@gmail.com</div>
                  <div class="email-meta">Added 1 month ago · Primary</div>
                </div>
                <span class="email-badge">Verified</span>
              </div>
            </div>
            <button class="add-email-btn" style="margin-top:10px" onclick="showToast('Add email dialog coming soon')">
