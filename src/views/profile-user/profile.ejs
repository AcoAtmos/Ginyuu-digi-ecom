                  <div class="form-actions">
                    <button class="btn btn-ghost" id="btnCancel">Cancel</button>
                    <button class="btn btn-primary" id="btnSave">Save Changes</button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </main>
    </div>

    <!-- Confirm Save Modal -->
    <div class="modal-overlay" id="confirmModal">
      <div class="modal">
        <div class="modal-title">Update Profile?</div>
        <div class="modal-desc">Are you sure you want to save these changes to your profile?</div>
        <div class="modal-actions">
