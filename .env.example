# ── Server ──
PORT=4100
NODE_ENV=development

# ── Database (PostgreSQL) ──
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=ginyuu
DATABASE_URL=postgres://your_db_user:your_db_password@localhost:5432/ginyuu

# ── JWT (Auth) ──
JWT_SECRET=your_jwt_secret

# ── URLs ──
BASE_URL=http://localhost:4100

# ── Bank Transfer ──
ACCOUNT_NUMBER=1234567890

# ── Email (Gmail SMTP) ──
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password

# ── WhatsApp API (external) ──
API_URL=https://notifapi.com
API_KEY=your_whatsapp_api_key

# ── QRIS Gateway (KlikQRIS) ──
BASE_URL_SANDBOX_API=https://klikqris.com/api/sandbox/qris/create
X_API_KEY=sk_sandbox_your_api_key
ID_MERCHANT=your_merchant_id

# ── Admin Panel ──
ADMIN_PORT=3100
ADMIN_BASE_URL=http://localhost:3100
ADMIN_JWT_SECRET=your_admin_jwt_secret
