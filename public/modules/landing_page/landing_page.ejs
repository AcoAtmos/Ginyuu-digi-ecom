<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GINYUU — Digital Products</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="../../assets/css/landing.css">
    <script  src="/assets/js/landing.js" type="module" defer></script>  
</head>
<body>

    <!-- ═══════════════════ NAVBAR ═══════════════════ -->
    <nav class="navbar">
    <button class="hamburger" id="hamburgerBtn" aria-label="Menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
    </button>
    <a href="#" class="navbar-brand">
        <span class="brand-logo">GIN<span style="color:#555">YUU</span></span>
    </a>

    <div class="navbar-search">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input type="text" id="searchInput" placeholder="Search Here…">
    </div>

    <div class="navbar-spacer"></div>

    <div class="navbar-actions">

        <!-- NOTIF -->
        <div class="nav-btn-wrap">
        <button class="nav-btn" id="notifBtn" aria-label="Notifikasi">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>
            </svg>
            <span class="badge" id="notifBadge">0</span>
        </button>
        <div class="dropdown notif-dropdown" id="notifDropdown">
            <div class="dropdown-header">NOTIFICATION</div>
            <div class="notif-list" id="notifList"></div>
            <div class="notif-footer" id="markAllRead">Read All</div>
        </div>
        </div>

        <!-- CART -->
        <div class="nav-btn-wrap">
        <button class="nav-btn" id="cartBtn" aria-label="Keranjang">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
            </svg>
            <span class="badge" id="cartBadge" style="display:none">0</span>
        </button>
        </div>

        <!-- PROFILE -->
        <div class="nav-btn-wrap">
        <button class="nav-btn" id="profileBtn" aria-label="Profil" style="width:auto;padding:0 6px;">
            <div class="profile-avatar" id="profileAvatar">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
            </svg>
            </div>
        </button>
        <div class="dropdown" id="profileDropdown" style="min-width:180px;">
            <div id="profileDropdownContent"></div>
        </div>
        </div>

    </div>
    </nav>

    <!-- ═══════════════════ SIDEBAR ═══════════════════ -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    <aside class="sidebar" id="sidebar">
    <span class="sidebar-section-title">Menu</span>
    <button class="sidebar-link active" data-cat="all">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
        </svg>
        All Product
    </button>
    <button class="sidebar-link" data-cat="template">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>
        </svg>
        Templates
    </button>
    <button class="sidebar-link" data-cat="ebook">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
        </svg>
        E-Books
    </button>
    <button class="sidebar-link" data-cat="course">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/>
        </svg>
        Courses
    </button>
    <button class="sidebar-link" data-cat="software">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
        </svg>
        Software
    </button>
    <button class="sidebar-link" data-cat="asset">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
        </svg>
        Digital Assets
    </button>

    <div class="sidebar-divider"></div>
    <span class="sidebar-section-title">Lainnya</span>
    <button class="sidebar-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="17" y1="1" x2="17" y2="11"/><line x1="1" y1="1" x2="1" y2="11"/>
        <path d="M1 7h16M17 3H3a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h14"/>
        </svg>
        Flash Sale
    </button>
    <button class="sidebar-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
        </svg>
        Trending
    </button>
    <button class="sidebar-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
        Wishlist
    </button>
    </aside>

    <!-- ═══════════════════ MAIN ═══════════════════ -->
    <div class="layout">
    <main class="main-content">

        <!-- HERO -->
        <div class="hero">
        <div class="hero-text">
            <h1>Digital Product<br><span>High Quality</span></h1>
            <p>Discover thousands of premium templates, e-books, courses, and digital assets to boost your productivity..</p>
            <div class="hero-cta">
            <button class="btn-primary" onclick="document.getElementById('productsSection').scrollIntoView({behavior:'smooth'})">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
                Explore Product
            </button>
            <button class="btn-secondary">Flash Sale</button>
            </div>
        </div>
        <div class="hero-stats">
            <div class="stat-item">
            <span class="stat-num" id="stat1">0</span>
            <span class="stat-label">Product</span>
            </div>
            <div class="stat-item">
            <span class="stat-num" id="stat2">0</span>
            <span class="stat-label">Buyer</span>
            </div>
            <div class="stat-item">
            <span class="stat-num" id="stat3">0</span>
            <span class="stat-label">Creator</span>
            </div>
        </div>
        </div>

        <!-- PRODUCTS SECTION -->
        <div id="productsSection">
        <div class="section-header">
            <h2 class="section-title">🔥 Hot Selling</h2>
            <span class="section-link">See all →</span>
        </div>

        <!-- FILTER PILLS -->
        <div class="filter-bar" id="filterBar">
            <button class="filter-pill active" data-cat="all">All</button>
            <button class="filter-pill" data-cat="template">Template</button>
            <button class="filter-pill" data-cat="ebook">E-Book</button>
            <button class="filter-pill" data-cat="course">Course</button>
            <button class="filter-pill" data-cat="software">Software</button>
            <button class="filter-pill" data-cat="asset">Digital Asset</button>
        </div>

        <!-- PRODUCT GRID -->
        <div class="product-grid" id="productGrid">
            <!-- Skeleton loaders -->
            <div class="skeleton"><div class="skeleton-thumb"></div><div class="skeleton-body"><div class="skeleton-line w40"></div><div class="skeleton-line w80"></div><div class="skeleton-line w60"></div></div></div>
            <div class="skeleton"><div class="skeleton-thumb"></div><div class="skeleton-body"><div class="skeleton-line w40"></div><div class="skeleton-line w80"></div><div class="skeleton-line w60"></div></div></div>
            <div class="skeleton"><div class="skeleton-thumb"></div><div class="skeleton-body"><div class="skeleton-line w40"></div><div class="skeleton-line w80"></div><div class="skeleton-line w60"></div></div></div>
            <div class="skeleton"><div class="skeleton-thumb"></div><div class="skeleton-body"><div class="skeleton-line w40"></div><div class="skeleton-line w80"></div><div class="skeleton-line w60"></div></div></div>
            <div class="skeleton"><div class="skeleton-thumb"></div><div class="skeleton-body"><div class="skeleton-line w40"></div><div class="skeleton-line w80"></div><div class="skeleton-line w60"></div></div></div>
            <div class="skeleton"><div class="skeleton-thumb"></div><div class="skeleton-body"><div class="skeleton-line w40"></div><div class="skeleton-line w80"></div><div class="skeleton-line w60"></div></div></div>
        </div>
        </div>

    </main>

    <!-- FOOTER -->
    <footer class="footer">
        <span class="footer-brand">GINYUU</span>
        <div class="footer-links">
        <a class="footer-link">Tentang Kami</a>
        <a class="footer-link">Bantuan</a>
        <a class="footer-link">Kebijakan Privasi</a>
        <a class="footer-link">Syarat & Ketentuan</a>
        </div>
        <span class="footer-copy">© 2025 Ginyuu. All rights reserved.</span>
    </footer>
    </div>

    <!-- ═══════════════════ CART SIDEBAR ═══════════════════ -->
    <div class="cart-overlay" id="cartOverlay"></div>
    <aside class="cart-sidebar" id="cartSidebar">
    <div class="cart-header">
        <span class="cart-title">Keranjang</span>
        <button class="cart-close" id="cartClose">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
        </button>
    </div>
    <div class="cart-body" id="cartBody"></div>
    <div class="cart-footer">
        <div class="cart-total-row">
        <span class="cart-total-label">Total</span>
        <span class="cart-total-price" id="cartTotal">Rp 0</span>
        </div>
        <button class="btn-checkout" id="checkoutBtn" disabled>Checkout</button>
    </div>
    </aside>

    <!-- ═══════════════════ PRODUCT MODAL ═══════════════════ -->
    <div class="modal-overlay" id="productModalOverlay">
    <div class="modal" id="productModal">
        <div class="product-modal-thumb" id="modalThumb">
        <button class="modal-close" id="productModalClose">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </button>
        <span id="modalEmoji" style="font-size:64px; position:relative;z-index:1;"></span>
        </div>
        <div class="modal-body">
        <div class="modal-category" id="modalCategory"></div>
        <div class="modal-title" id="modalTitle"></div>
        <div class="modal-rating" id="modalRating"></div>
        <div class="modal-desc" id="modalDesc"></div>
        <div class="modal-tags" id="modalTags"></div>
        <div class="modal-footer">
            <div class="modal-price-block">
            <span class="modal-price-old" id="modalPriceOld"></span>
            <span class="modal-price" id="modalPrice"></span>
            </div>
            <div class="modal-actions">
            <button class="btn-add-cart" id="modalAddCart">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                </svg>
                Add to Cart
            </button>
            <button class="btn-buy" id="modalBuyNow">
                Buy now
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
            </button>
            </div>
        </div>
        </div>
    </div>
    </div>

    <!-- ═══════════════════ AUTH MODAL ═══════════════════ -->
    <div class="modal-overlay" id="authModalOverlay">
    <div class="modal auth-modal" id="authModal">
        <div class="modal-body">
        <button class="modal-close" id="authModalClose" style="position:static;float:right;background:var(--bg3);border:1px solid var(--border2);">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </button>
        <div style="clear:both;"></div>
        <div class="auth-tabs">
            <button class="auth-tab active" id="tabLogin" onclick="switchTab('login')">Login</button>
            <button class="auth-tab" id="tabRegister" onclick="switchTab('register')">Register</button>
        </div>
        <div id="loginForm">
            <div class="auth-title">Welcome!</div>
            <div class="auth-subtitle">Login to your account</div>
            <div class="form-group">
            <label class="form-label">EMAIL</label>
            <input class="form-input" type="email" placeholder="nama@email.com" id="loginEmail">
            </div>
            <div class="form-group">
            <label class="form-label">PASSWORD</label>
            <input class="form-input" type="password" placeholder="••••••••" id="loginPassword">
            </div>
            <button class="btn-auth" onclick="handleLogin()">Login</button>
            <div class="auth-footer-text">Don't have an account? <a onclick="switchTab('register')">Register now</a></div>
        </div>
        <div id="registerForm" style="display:none;">
            <div class="auth-title">Create new account</div>
            <div class="auth-subtitle">Join thousands of users</div>
            <div class="form-group">
                <label class="form-label">USERNAME</label>
                <input class="form-input" type="text" placeholder="Username Anda" id="regUsername">
            </div>
            <div class="form-group">
                <label class="form-label">EMAIL</label>
                <input class="form-input" type="email" placeholder="nama@email.com" id="regEmail">
            </div>
            <div class="form-group">
                <label class="form-label">PASSWORD</label>
                <input class="form-input" type="password" placeholder="Min. 8 karakter" id="regPassword">
            </div>
            <div class="form-group">
                <label class="form-label">CONFIRM PASSWORD</label>
                <input class="form-input" type="password" placeholder="Min. 8 karakter" id="regConfirmPassword">
            </div>
            <div class="form-group">
                <input type="checkbox" id="regTerms" name="regTerms">
                <label for="regTerms">I agree to the <a class="syaratKet" href="#">terms and conditions</a></label>
            </div> 
            <button class="btn-auth" onclick="handleRegister()">Create Account</button>
            <div class="auth-footer-text">Already have an account? <a onclick="switchTab('login')">Login</a></div>
        </div>
        </div>
    </div>
    </div>
</body>
</html>
