<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ginyuu - Browse All Products</title>
    <script>window.BE_URL = "<%= BE_URL || 'http://localhost:4100' %>";</script>
<link rel="stylesheet" href="/assets/css/navbar.css">
  <link rel="stylesheet" href="/assets/css/shared.css">
  <link rel="stylesheet" href="/assets/css/browsAll.css">
    <script type="module" src="/assets/js/browsAll.js" defer></script>
    <!-- icon -->
    <link rel="icon" href="/assets/img/icon/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/img/icon/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/img/icon/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/img/icon/apple-touch-icon.png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Sora:wght@600;700;800&display=swap" rel="stylesheet">
</head>
<body data-page="browsAll">
    <%- include('../../common/view/navbar.ejs') %>

    <!-- Breadcrumb -->
    <div class="breadcrumb">
        <a href="/page/home">Home</a>
        <span>›</span>
        <span>Browse All</span>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <!-- Filters Sidebar -->
        <aside class="filters-sidebar">
            <!-- Category Filter -->
            <div class="filter-section">
                <div class="filter-header">
                    <h3>Categories</h3>
                    <button class="filter-clear" data-clear="category">Clear</button>
                </div>
                <div class="filter-options">
                    <div class="filter-option">
                        <input type="checkbox" id="cat-ui" value="UI Kit" class="category-filter">
                        <label for="cat-ui">UI Kits <span class="filter-count">28</span></label>
                    </div>
                    <div class="filter-option">
                        <input type="checkbox" id="cat-template" value="Template" class="category-filter">
                        <label for="cat-template">Templates <span class="filter-count">18</span></label>
                    </div>
                    <div class="filter-option">
                        <input type="checkbox" id="cat-illustration" value="Illustration" class="category-filter">
                        <label for="cat-illustration">Illustrations <span class="filter-count">15</span></label>
                    </div>
                    <div class="filter-option">
                        <input type="checkbox" id="cat-icon" value="Icon" class="category-filter">
                        <label for="cat-icon">Icons <span class="filter-count">22</span></label>
                    </div>
                </div>
            </div>

            <!-- Price Filter -->
            <div class="filter-section">
                <div class="filter-header">
                    <h3>Price Range</h3>
                    <button class="filter-clear" data-clear="price">Clear</button>
                </div>
                <div class="price-inputs">
                    <div class="price-input">
                        <label>Min</label>
                        <input type="number" id="minPrice" placeholder="0" min="0">
                    </div>
                    <div class="price-input">
                        <label>Max</label>
                        <input type="number" id="maxPrice" placeholder="500+" min="0">
                    </div>
                </div>
            </div>

            <!-- Rating Filter -->
            <div class="filter-section">
                <div class="filter-header">
                    <h3>Rating</h3>
                    <button class="filter-clear" data-clear="rating">Clear</button>
                </div>
                <div class="filter-options">
                    <div class="filter-option">
                        <input type="radio" id="rating-5" name="rating" value="5" class="rating-filter">
                        <label for="rating-5">★★★★★ <small>& up</small></label>
                    </div>
                    <div class="filter-option">
                        <input type="radio" id="rating-4" name="rating" value="4" class="rating-filter">
                        <label for="rating-4">★★★★☆ <small>& up</small></label>
                    </div>
                    <div class="filter-option">
                        <input type="radio" id="rating-3" name="rating" value="3" class="rating-filter">
                        <label for="rating-3">★★★☆☆ <small>& up</small></label>
                    </div>
                </div>
            </div>

            <button class="apply-filters" id="applyFilters">Apply Filters</button>
        </aside>

        <!-- Products Section -->
        <section class="products-section">
            <div class="products-header">
                <div>
                    <h1>Browse All Products</h1>
                    <p class="products-count">Showing <span id="productCount">0</span> products</p>
                </div>
                <div class="sort-filter">
                    <button class="filter-mobile-btn" id="filterMobileBtn">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/>
                        </svg>
                        Filters
                    </button>
                    <select class="sort-select" id="sortSelect">
                        <option value="featured">Most Popular</option>
                        <option value="price-low">Price: Low → High</option>
                        <option value="price-high">Price: High → Low</option>
                        <option value="rating">Highest Rated</option>
                        <option value="newest">Newest First</option>
                    </select>
                </div>
            </div>

            <div class="product-grid" id="productGrid"></div>

            <!-- Pagination -->
            <div class="pagination-wrapper" id="paginationWrapper">
                <div class="pagination">
                    <button class="pagination-btn pagination-prev" id="prevBtn" disabled>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M15 18l-6-6 6-6"/>
                        </svg>
                        Prev
                    </button>
                    <div class="pagination-numbers" id="paginationNumbers"></div>
                    <button class="pagination-btn pagination-next" id="nextBtn">
                        Next
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M9 18l6-6-6-6"/>
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Empty State -->
            <div class="empty-state" id="emptyState" style="display: none;">
                <div class="empty-state-icon">🔍</div>
                <h3>No products found</h3>
                <p>Try adjusting your filters or search terms</p>
                <button id="clearAllFilters">Clear All Filters</button>
            </div>
        </section>
    </div>

    <!-- Mobile Filter Overlay -->
    <div class="filter-overlay" id="filterOverlay"></div>
    <div class="filter-mobile" id="filterMobile">
        <div class="filter-mobile-header">
            <h2>Filters</h2>
            <button class="filter-close" id="filterClose">×</button>
        </div>
        <div id="mobileFiltersContent"></div>
    </div>
    
    <!-- Footer -->
    <%- include('../../common/view/footer.ejs') %>

    <!-- Product Modal -->
    <div class="modal" id="productModal">
        <div class="modal-content">
            <button class="modal-close" id="modalClose">×</button>
            <div class="modal-body">
                <div class="modal-image" id="modalImageContainer">
                    <span class="product-icon">📱</span>
                </div>
                <div class="modal-details">
                    <span class="modal-category" id="modalCategory">Product</span>
                    <h2 id="modalTitle">Product Title</h2>
                    <div class="modal-rating">
                        <span class="stars">★★★★★</span>
                        <span class="rating-text" id="modalRating">0/5 (0 reviews)</span>
                    </div>
                    <p class="modal-description" id="modalDescription">
                        Product description will appear here.
                    </p>
                    <div class="modal-price">
                        <span class="modal-current-price" id="modalPrice">Rp 0</span>
                        <span class="modal-original-price" id="modalOriginalPrice" style="display:none;">Rp 0</span>
                        <span class="discount" id="modalDiscount" style="display:none;">-0%</span>
                    </div>
                    <div class="modal-actions">
                        <button class="btn-primary" id="order_now_btn">Order Now</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
