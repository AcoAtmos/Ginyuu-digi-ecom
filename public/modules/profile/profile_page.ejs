<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Ginyuu — My Profile</title>
  <script>window.BE_URL = "<%= BE_URL || 'http://localhost:4100' %>";</script>
  <link rel="stylesheet" href="/assets/css/navbar.css">
  <link rel="stylesheet" href="/assets/css/shared.css">
  <link rel="stylesheet" href="/assets/css/profile.css">
  <script type="module" src="/assets/js/profile.js" defer></script>
  <link rel="icon" href="/assets/img/icon/favicon.ico">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Sora:wght@600;700;800&display=swap" rel="stylesheet">
</head>
<body data-page="profile">
  <%- include('../../common/view/navbar.ejs') %>

  <main class="profile-main">
    <header class="profile-header">
      <div class="avatar-container">
        <span id="profileAvatar" class="avatar-letter">U</span>
      </div>
      <h1 id="profileUsername" class="profile-name">Loading...</h1>
      <p id="profileEmail" class="profile-email">...</p>

      <div class="profile-stats">
        <div class="stat-item">
          <div id="productCount" class="stat-number">0</div>
          <div class="stat-label">Products Owned</div>
        </div>
        <div class="stat-item">
          <div id="purchaseCount" class="stat-number">0</div>
          <div class="stat-label">Purchases</div>
        </div>
        <div class="stat-item">
          <div id="daysActive" class="stat-number">0</div>
          <div class="stat-label">Days Active</div>
        </div>
      </div>
    </header> 

    <div class="tabs">
      <button class="tab active" data-tab="overview">Overview</button>
      <button class="tab" data-tab="purchases">Purchases</button>
      <button class="tab" data-tab="settings">Settings</button>
    </div>

    <!-- Tab: Overview -->
    <div id="overview" class="tab-content">
      <h2 class="section-title">Account Info</h2>
      <div class="info-card">
        <table class="info-table">
          <tr>
            <td class="info-label">Username</td>
            <td id="profileUsername2" class="info-value">-</td>
          </tr>
          <tr>
            <td class="info-label">Email</td>
            <td id="profileEmail2" class="info-value">-</td>
          </tr>
          <tr>
            <td class="info-label">Phone</td>
            <td id="profilePhone" class="info-value">-</td>
          </tr>
          <tr>
            <td class="info-label">Role</td>
            <td id="profileRole" class="info-value">-</td>
          </tr>
          <tr>
            <td class="info-label">Member Since</td>
            <td id="profileCreated" class="info-value">-</td>
          </tr>
        </table>
      </div>
    </div>

    <!-- Tab: Purchases -->
    <div id="purchases" class="tab-content" style="display: none;">
      <h2 class="section-title">Your Purchases</h2>
      <div class="table-container">
        <table class="profile-table" id="purchaseTable">
          <thead>
            <tr id="purchaseTableHeader">
              <th>Product</th>
              <th>Date</th>
              <th>Total</th>
              <th>Invoice</th>
              <th>Payment</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody id="purchaseTableBody">
            <tr><td colspan="6" class="loading-cell">Loading...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Tab: Settings -->
    <div id="settings" class="tab-content" style="display: none;">
      <h2 class="section-title">Account Settings</h2>
      <div class="settings-form">
        <div class="form-group">
          <label class="form-label">Username</label>
          <input type="text" id="settingsUsername" class="form-input">
        </div>
        <div class="form-group">
          <label class="form-label">Email</label>
          <input type="email" id="settingsEmail" class="form-input" disabled>
        </div>
        <button class="btn-save">Save Changes</button>
      </div>
    </div>
  </main>

  <script>
    document.querySelectorAll('.tab').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.querySelectorAll('.tab-content').forEach(c => c.style.display = 'none');
        document.getElementById(btn.dataset.tab).style.display = 'block';
      });
    });
  </script>
</body>
</html>