<!DOCTYPE html >
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ginyuu - Premium Digital Products</title>
    <script>window.BE_URL = "<%= BE_URL || 'http://localhost:4100' %>";</script>
<link rel="stylesheet" href="/assets/css/navbar.css">
  <link rel="stylesheet" href="/assets/css/shared.css">
  <link rel="stylesheet" href="/assets/css/home.css">
    <script type="module" src="/assets/js/home.js" defer></script>
    <!-- icon -->
    <link rel="icon" href="/assets/img/icon/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/img/icon/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/img/icon/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/img/icon/apple-touch-icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Sora:wght@600;700;800&display=swap" rel="stylesheet">
</head>
<body data-page="home">
    <%- include('../../common/view/navbar.ejs') %>

    <!-- Hero Section -->
    <section class="hero">
        <div class="container">
            <div class="hero-content">
                <div class="hero-badge">
                    <span class="hero-badge-text">Premium Digital Products</span>
                </div>
                
                <h1>Unleash the <span class="highlight">traveler</span> inside you</h1>
                
                <p>Discover breathtaking destinations around the world. Get exclusive access to premium travel packages and unforgettable experiences.</p>
                
                <div class="hero-stats">
                    <div class="hero-stat">
                        <div class="hero-stat-number">500+</div>
                        <div class="hero-stat-label">Premium Products</div>
                    </div>
                    <div class="hero-stat">
                        <div class="hero-stat-number">50K+</div>
                        <div class="hero-stat-label">Happy Customers</div>
                    </div>
                    <div class="hero-stat">
                        <div class="hero-stat-number">4.9</div>
                        <div class="hero-stat-label">Rating</div>
                    </div>
                </div>
                
                <div class="hero-cta">
                    <a href="/page/browsAll" class="hero-btn hero-btn-primary">Explore Now →</a>
                    <a href="#categories" class="hero-btn hero-btn-secondary">View Categories</a>
                </div>
            </div>
            
            <div class="hero-image">
                <img src="/assets/img/home/businessman-his-office-with-thumb-up.jpg" alt="Hero">
            </div>
        </div>
    </section>

    <!-- New Arrivals Section -->
    <section class="section" id="new-arrivals">
        <div class="section-header">
            <h2>NEW ARRIVALS</h2>
            <p>Check out our latest digital products fresh from talented creators</p>
        </div>
        <div class="product-grid" id="grid_new_arrival_container"></div>
    </section>

    <!-- Top Selling Section -->
    <section class="section" id="top-selling">
        <div class="section-header">
            <h2>TOP SELLING</h2>
            <p>Best-selling products loved by designers worldwide</p>
        </div>
        <div class="product-grid" id="grid_top_selling_container"></div>
    </section>

    <!-- Browse by Category Section -->
    <section class="section" id="categories">
        <div class="section-header">
            <h2>BROWSE BY CATEGORY</h2>
            <p>Find exactly what you need for your next project</p>
        </div>
        <div class="category-grid">
            <div class="category-card">
                <div class="category-icon">
                    <svg class="w-6 h-6 text-gray-800 dark:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                        <path fill-rule="evenodd" d="M11.32 6.176H5c-1.105 0-2 .949-2 2.118v10.588C3 20.052 3.895 21 5 21h11c1.105 0 2-.948 2-2.118v-7.75l-3.914 4.144A2.46 2.46 0 0 1 12.81 16l-2.681.568c-1.75.37-3.292-1.263-2.942-3.115l.536-2.839c.097-.512.335-.983.684-1.352l2.914-3.086Z" clip-rule="evenodd"/>
                        <path fill-rule="evenodd" d="M19.846 4.318a2.148 2.148 0 0 0-.437-.692 2.014 2.014 0 0 0-.654-.463 1.92 1.92 0 0 0-1.544 0 2.014 2.014 0 0 0-.654.463l-.546.578 2.852 3.02.546-.579a2.14 2.14 0 0 0 .437-.692 2.244 2.244 0 0 0 0-1.635ZM17.45 8.721 14.597 5.7 9.82 10.76a.54.54 0 0 0-.137.27l-.536 2.84c-.07.37.239.696.588.622l2.682-.567a.492.492 0 0 0 .255-.145l4.778-5.06Z" clip-rule="evenodd"/>
                    </svg>
                </div>
                <div class="category-name">UI Kits</div>
            </div>
            <div class="category-card">
                <div class="category-icon">
                    <svg class="w-6 h-6 text-gray-800 dark:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                        <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2ZM7.99 9a1 1 0 0 1 1-1H9a1 1 0 0 1 0 2h-.01a1 1 0 0 1-1-1ZM14 9a1 1 0 0 1 1-1h.01a1 1 0 1 1 0 2H15a1 1 0 0 1-1-1Zm-5.506 7.216A5.5 5.5 0 0 1 6.6 13h10.81a5.5 5.5 0 0 1-8.916 3.216Z" clip-rule="evenodd"/>
                    </svg>
                </div>
                <div class="category-name">Icon Packs</div>
            </div>
            <div class="category-card">
                <div class="category-icon">
                    <svg class="w-6 h-6 text-gray-800 dark:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                        <path fill-rule="evenodd" d="M11.32 6.176H5c-1.105 0-2 .949-2 2.118v10.588C3 20.052 3.895 21 5 21h11c1.105 0 2-.948 2-2.118v-7.75l-3.914 4.144A2.46 2.46 0 0 1 12.81 16l-2.681.568c-1.75.37-3.292-1.263-2.942-3.115l.536-2.839c.097-.512.335-.983.684-1.352l2.914-3.086Z" clip-rule="evenodd"/>
                        <path fill-rule="evenodd" d="M19.846 4.318a2.148 2.148 0 0 0-.437-.692 2.014 2.014 0 0 0-.654-.463 1.92 1.92 0 0 0-1.544 0 2.014 2.014 0 0 0-.654.463l-.546.578 2.852 3.02.546-.579a2.14 2.14 0 0 0 .437-.692 2.244 2.244 0 0 0 0-1.635ZM17.45 8.721 14.597 5.7 9.82 10.76a.54.54 0 0 0-.137.27l-.536 2.84c-.07.37.239.696.588.622l2.682-.567a.492.492 0 0 0 .255-.145l4.778-5.06Z" clip-rule="evenodd"/>
                    </svg>
                </div>
                <div class="category-name">Templates</div>
            </div>
            <div class="category-card">
                <div class="category-icon">
                    <svg class="w-6 h-6 text-gray-800 dark:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                        <path fill-rule="evenodd" d="M13 10a1 1 0 0 1 1-1h.01a1 1 0 1 1 0 2H14a1 1 0 0 1-1-1Z" clip-rule="evenodd"/>
                        <path fill-rule="evenodd" d="M2 6a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v12c0 .556-.227 1.06-.593 1.422A.999.999 0 0 1 20.5 20H4a2.002 2.002 0 0 1-2-2V6Zm6.892 12 3.833-5.356-3.99-4.322a1 1 0 0 0-1.549.097L4 12.879V6h16v9.95l-3.257-3.619a1 1 0 0 0-1.557.088L11.2 18H8.892Z" clip-rule="evenodd"/>
                    </svg>
                </div>
                <div class="category-name">Illustrations</div>
            </div>
        </div>
    </section>

    <!-- Reviews Section -->
    <section class="section" id="reviews">
        <div class="section-header">
            <h2>HAPPY CUSTOMERS</h2>
            <p>See what our customers say about their purchases</p>
        </div>
        <div class="reviews-grid">
            <div class="review-card">
                <div class="review-header">
                    <div class="reviewer-avatar">SM</div>
                    <div class="reviewer-info">
                        <h4>Sarah Mitchell</h4>
                        <div class="product-rating">
                            <span class="stars">★★★★★</span>
                        </div>
                    </div>
                </div>
                <div class="review-text">
                    "The Mobile UI Kit Pro is absolutely stunning! It saved me weeks of work on my recent project. The attention to detail and quality of components is top-notch."
                </div>
            </div>

            <div class="review-card">
                <div class="review-header">
                    <div class="reviewer-avatar">JD</div>
                    <div class="reviewer-info">
                        <h4>James Davis</h4>
                        <div class="product-rating">
                            <span class="stars">★★★★★</span>
                        </div>
                    </div>
                </div>
                <div class="review-text">
                    "I've purchased several icon packs before, but this 3D Icon Pack is on another level. The variety and quality are exceptional. Perfect for modern web design!"
                </div>
            </div>

            <div class="review-card">
                <div class="review-header">
                    <div class="reviewer-avatar">EW</div>
                    <div class="reviewer-info">
                        <h4>Emily Watson</h4>
                        <div class="product-rating">
                            <span class="stars">★★★★★</span>
                        </div>
                    </div>
                </div>
                <div class="review-text">
                    "The Dashboard UI Kit transformed how I approach admin panel designs. Everything is well-organized, customizable, and looks professional."
                </div>
            </div>
        </div>
    </section>

    <!-- Newsletter Section -->
    <div class="newsletter">
        <h2>STAY UP TO DATE</h2>
        <p>Subscribe to get special offers, free giveaways, and exclusive deals.</p>
        <form class="newsletter-form" id="newsletterForm">
            <input type="email" placeholder="Enter your email address" required>
            <button type="submit">Subscribe</button>
        </form>
    </div>

    <!-- Footer -->
    <%- include('../../common/view/footer.ejs') %>

    <!-- Product Modal -->
    <div class="modal" id="productModal">
        <div class="modal-content">
            <button class="modal-close" id="modalClose">×</button>
            <div class="modal-body">
                <div class="modal-image" id="modalImageContainer">
                    <span class="product-icon">📱</span>
                </div>
                <div class="modal-details">
                    <span class="modal-category" id="modalCategory">Product</span>
                    <h2 id="modalTitle">Product Title</h2>
                    <div class="modal-rating">
                        <span class="stars">★★★★★</span>
                        <span class="rating-text" id="modalRatingText">0/5 (0 reviews)</span>
                    </div>
                    <p class="modal-description" id="modalDescription">
                        Product description will appear here.
                    </p>
                    <div class="modal-price">
                        <span class="modal-current-price" id="modalPrice">Rp 0</span>
                        <span class="modal-original-price" id="modalOriginalPrice" style="display:none;">Rp 0</span>
                        <span class="discount" id="modalDiscount" style="display:none;">-0%</span>
                    </div>
                    <div class="modal-actions">
                        <button class="btn-primary" id="order_now_btn">Order Now</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scroll to Top Button -->
    <button class="scroll-top" id="scrollTop">↑</button>
</body>
</html>
