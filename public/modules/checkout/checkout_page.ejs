<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ginyuu - Checkout</title>
    <script>window.BE_URL = "<%= BE_URL || 'http://localhost:4100' %>";</script>
<link rel="stylesheet" href="/assets/css/navbar.css">
  <link rel="stylesheet" href="/assets/css/shared.css">
  <link rel="stylesheet" href="/assets/css/checkout.css">
    <script type="module" src="/assets/js/checkout.js" defer></script>
    <link rel="icon" href="/assets/img/icon/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/img/icon/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/img/icon/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/img/icon/apple-touch-icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Sora:wght@600;700;800&display=swap" rel="stylesheet">
</head>

<body class="checkout-page" data-page="checkout">
    <header class="main-header" style="position: relative; background: rgba(10, 10, 15, 0.95);">
        <div class="header-container">
            <a href="/page/home" class="logo">GINY<span>UU</span></a>
            <div class="steps">
                <div class="step active">
                    <span class="number">✓</span>
                    <span>Checkout</span>
                </div>
            </div>
        </div>
    </header>

    <div class="container" style="padding-top: 2rem;">
        <div class="content">
            <div class="checkout-form">
                <h1>Checkout</h1>
                <div id="user-info-section">
                    <div class="form-group">
                        <label>Name/ Username <span class="required">*</span></label>
                        <input type="text" id="username" placeholder="Enter full name">
                    </div>

                    <div class="form-group dataNeeded">
                        <label>Password <span class="required">*</span></label>
                        <input type="password" id="password" placeholder="Enter Password">
                    </div>

                    <div class="form-group dataNeeded">
                        <label>Confirm Password <span class="required">*</span></label>
                        <input type="password" id="confirm-password" placeholder="Confirm Password">
                    </div>

                    <div class="form-group">
                        <label>Email address <span class="required">*</span></label>
                        <input type="email" id="email" placeholder="Enter email address">
                    </div>

                    <div class="form-group">
                        <label>Phone number <span class="required">*</span></label>
                        <div class="phone-input">
                            <input type="text" id="+62" value="+62" disabled>
                            <input type="tel" id="phone" placeholder="Enter phone number" onblur="hit_api_check_whatsapp()">
                        </div>
                        <p id="phone-error" style="display: none;"></p>
                    </div>
                </div>

                <div class="payment-section">
                    <label class="section-title">Choose your payment method *</label>

                    <div class="payment-options">
                        <label class="payment-card">
                            <input type="radio" name="payment_method" value="qris">
                            <span>QRIS</span>
                        </label>

                        <label class="payment-card">
                            <input type="radio" name="payment_method" value="bank">
                            <span>Transfer Bank</span>
                        </label>

                        <label class="payment-card">
                            <input type="radio" name="payment_method" value="ewallet">
                            <span>E-Wallet</span>
                        </label>
                    </div>

                    <div class="payment-extra" id="bank-input" style="display: none;">
                        <select id="bank-name">
                            <option value="" disabled selected>Pilih Bank</option>
                            <option value="BCA">BCA</option>
                            <option value="BNI">BNI</option>
                            <option value="BRI">BRI</option>
                            <option value="MANDIRI">Mandiri</option>
                        </select>
                    </div>

                    <div class="payment-extra" id="ewallet-input" style="display: none;">
                        <select id="ewallet-name">
                            <option value="" disabled selected>Pilih E-Wallet</option>
                            <option value="gopay">GoPay</option>
                            <option value="ovo">OVO</option>
                            <option value="dana">DANA</option>
                            <option value="shopeepay">ShopeePay</option>
                        </select>
                    </div>
                </div>

                <div class="checkbox-group">
                    <input type="checkbox" id="terms" checked>
                    <label for="terms">I have read and agree to the Terms and Conditions.</label>
                </div>
            </div>

            <div class="cart-review">
                <h2>Review your cart</h2>
                <div class="product-item" id="product-item">
                    <div class="product-info">
                        <div class="product-name"></div>
                        <div class="product-qty"></div>
                    </div>
                    <div class="product-price">RP. 0</div>
                </div>

                <div class="bonus-notification" id="bonus-notification" style="display: none;">
                    <div class="bonus-content">
                        <div class="bonus-icon">🎁</div>
                        <div class="bonus-text">
                            <strong>Special Offer!</strong>
                            <p>Upgrade to 12-month plan and get <span class="highlight">30% OFF</span></p>
                        </div>
                        <button class="upgrade-btn" id="upgrade-btn">Upgrade Now</button>
                    </div>
                </div>

                <div class="discount-applied-notice" id="discount-applied-notice" style="display: none;">
                    <div class="notice-content">
                        <div class="check-icon">✓</div>
                        <div class="notice-text">
                            <strong>Discount Applied!</strong>
                            <p>You're getting <span class="highlight">30% OFF</span> on the 12-month plan</p>
                        </div>
                    </div>
                </div>

                <div class="discount-code">
                    <span>🎟️</span>
                    <input type="text" id="discount-input" placeholder="Discount code" value="">
                    <button class="apply-btn" id="Apply-discount">Apply</button>
                </div>

                <div class="summary" id="summary">
                    <div class="summary-row subtotal">
                        <span>Subtotal</span>
                        <span>RP. 0</span>
                    </div>
                    <div class="summary-row discount">
                        <span>Discount</span>
                        <span>-Rp. 0</span>
                    </div>
                    <div class="summary-row total">
                        <span>Total</span>
                        <span>RP. 0</span>
                    </div>
                </div>

                <button class="pay-btn" id="pay-btn">Pay Now</button>

                <div class="secure-notice">
                    <span class="lock">🔒</span>
                    <div>
                        <h3>Secure Checkout - SSL Encrypted</h3>
                        <p>Ensuring your financial and personal details are secure during every transaction.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
