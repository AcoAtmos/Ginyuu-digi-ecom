<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"> 
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ginyuu - Waiting for Payment</title>
    <script>window.BE_URL = "<%= BE_URL || 'http://localhost:4100' %>";</script>
    <link rel="stylesheet" href="/assets/css/shared.css">
    <link rel="stylesheet" href="/assets/css/waiting_payment.css">
    <script src="/assets/js/waiting_payment.js" defer></script>
    <link rel="icon" href="/assets/img/icon/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/img/icon/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/img/icon/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/img/icon/apple-touch-icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Sora:wght@600;700;800&display=swap" rel="stylesheet">
</head>
<body data-page="waiting_payment">
    <header class="main-header" style="position: relative; background: rgba(10, 10, 15, 0.95);">
        <div class="header-container">
            <a href="/page/home" class="logo">GINY<span>UU</span></a>
            <a href="/page/checkout/<%= typeof slug !== 'undefined' ? slug : '' %>" class="back-link" style="color: rgba(255,255,255,0.7);">← Back to Checkout</a>
        </div>
    </header>

    <div class="container" style="padding-top: 2rem; max-width: 600px;">
        <div class="status-icon">
            <div class="clock-icon"></div>
        </div>

        <h1>Waiting for Payment</h1>
        <p class="subtitle">Please complete your payment to activate your subscription</p>

        <div class="payment-method-badge" id="payment-badge"></div>

        <div class="timer-section">
            <div class="timer-label">Payment expires in</div>
            <div class="timer" id="countdown">15:00</div>
        </div>

        <div class="qr-section" id="qris-section">
            <div class="qr-code">📱</div>
            <p class="qr-instruction">Scan this QR code with your mobile banking or e-wallet app</p>
        </div>

        <div class="bank-section" id="bank-section">
            <h3>Transfer to Bank Account</h3>
            <div class="bank-info">
                <div class="bank-detail">
                    <span class="bank-label">Bank Name</span>
                    <span class="bank-value">BCA (Bank Central Asia)</span>
                </div>
                <div class="bank-detail">
                    <span class="bank-label">Account Number</span>
                    <div>
                        <span class="bank-value" id="account-number">1234567890</span>
                        <button class="copy-btn" onclick="copyText('account-number')">Copy</button>
                    </div>
                </div>
                <div class="bank-detail">
                    <span class="bank-label">Account Name</span>
                    <span class="bank-value">PT Manjuu Indonesia</span>
                </div>
                <div class="bank-detail" style="border-top: 1px solid rgba(255,255,255,0.1); padding-top: 1rem; margin-top: 0.75rem;">
                    <span class="bank-label">Transfer Amount</span>
                    <div>
                        <span class="bank-value" style="color: #60a5fa;" id="transfer-amount">RP. 700,000</span>
                        <button class="copy-btn" onclick="copyText('transfer-amount')">Copy</button>
                    </div>
                </div>
            </div>
            <p class="warning-text">⚠️ Please transfer the exact amount shown above</p>
        </div>

        <div class="ewallet-section" id="ewallet-section">
            <h3>Select Your E-Wallet</h3>
            <div class="ewallet-options">
                <div class="ewallet-card" onclick="selectEwallet('gopay')">
                    <div class="ewallet-icon">💚</div>
                    <div class="ewallet-name">GoPay</div>
                </div>
                <div class="ewallet-card" onclick="selectEwallet('ovo')">
                    <div class="ewallet-icon">💜</div>
                    <div class="ewallet-name">OVO</div>
                </div>
                <div class="ewallet-card" onclick="selectEwallet('dana')">
                    <div class="ewallet-icon">💙</div>
                    <div class="ewallet-name">DANA</div>
                </div>
                <div class="ewallet-card" onclick="selectEwallet('shopeepay')">
                    <div class="ewallet-icon">🧡</div>
                    <div class="ewallet-name">ShopeePay</div>
                </div>
            </div>
            <div class="ewallet-number" id="ewallet-number-box" style="display: none;">
                <div class="ewallet-number-label">Send payment to:</div>
                <div class="ewallet-number-value" id="ewallet-number">0812-3456-7890</div>
                <button class="copy-btn" onclick="copyText('ewallet-number')">Copy Number</button>
            </div>
        </div>

        <div class="payment-details">
            <div class="detail-row">
                <span class="detail-label">Invoice Number</span>
                <span class="detail-value" id="invoice-number">-</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Payment Method</span>
                <span class="detail-value" id="payment-method">-</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Buyer</span>
                <span class="detail-value" id="buyer-name">-</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Product</span>
                <span class="detail-value" id="product-name">-</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Quantity</span>
                <span class="detail-value" id="quantity">-</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Discount</span>
                <span class="detail-value" id="discount-value">RP. 0</span>
            </div>
            <div class="total-row detail-row">
                <span class="detail-label">Total Amount</span>
                <span class="detail-value" id="total-amount">-</span>
            </div>
        </div>

        <div class="loading-dots">
            <div class="dot"></div>
            <div class="dot"></div>
            <div class="dot"></div>
        </div>
        <p class="status-message">Checking payment status...</p>

        <div class="instructions" id="instructions">
            <h3>How to Pay:</h3>
            <ol id="instruction-list">
                <li>Open your mobile banking or e-wallet app</li>
                <li>Select "Scan QR" or "QRIS" option</li>
                <li>Scan the QR code shown above</li>
                <li>Confirm the payment amount</li>
                <li>Complete the transaction</li>
            </ol>
        </div>

        <div class="button-group">
            <button class="btn btn-secondary" onclick="window.history.back()">Back to Checkout</button>
            <button class="btn btn-primary" onclick="checkPayment()">Check Payment Status</button>
        </div>
    </div>
</body>
</html>
