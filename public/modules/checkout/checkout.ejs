<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Checkout — DIGISTORE</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg:       #0a0a0a;
  --bg2:      #111111;
  --bg3:      #1a1a1a;
  --bg4:      #222222;
  --border:   #2a2a2a;
  --border2:  #333333;
  --border3:  #444444;
  --text:     #f0f0f0;
  --text2:    #999999;
  --text3:    #555555;
  --accent:   #ffffff;
  --danger:   #ff4444;
  --success:  #44dd88;
  --radius:   14px;
  --radius-sm:8px;
  --navbar-h: 64px;
  --shadow:   0 12px 40px rgba(0,0,0,.7);
  --shadow-sm:0 2px 12px rgba(0,0,0,.4);
}

html { scroll-behavior: smooth; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  font-size: 15px;
  line-height: 1.6;
  min-height: 100vh;
}

::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--bg2); }
::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }

/* ─── NAVBAR ─── */
.navbar {
  position: sticky; top: 0; z-index: 100;
  height: var(--navbar-h);
  background: rgba(10,10,10,.92);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center;
  padding: 0 28px;
  gap: 16px;
}
.nav-back {
  display: flex; align-items: center; gap: 8px;
  background: none; border: none; cursor: pointer;
  color: var(--text2); font-family: inherit; font-size: 14px;
  padding: 8px 12px;
  border-radius: 999px;
  transition: background .15s, color .15s;
}
.nav-back:hover { background: var(--bg3); color: var(--text); }
.nav-brand {
  font-family: 'Syne', sans-serif;
  font-weight: 800; font-size: 18px;
  color: var(--text); text-decoration: none;
  letter-spacing: -.5px;
}
.nav-brand span { color: var(--text3); }
.nav-spacer { flex: 1; }
.nav-secure {
  display: flex; align-items: center; gap: 6px;
  font-size: 12px; color: var(--text3);
  background: var(--bg3); border: 1px solid var(--border);
  padding: 6px 12px; border-radius: 999px;
}
.nav-secure svg { color: var(--success); }

/* ─── PROGRESS BAR ─── */
.progress-wrap {
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  padding: 0 28px;
}
.progress-steps {
  display: flex; align-items: center;
  max-width: 900px; margin: 0 auto;
  padding: 16px 0;
  gap: 0;
}
.progress-step {
  display: flex; align-items: center; gap: 10px;
  flex: 1;
}
.step-num {
  width: 28px; height: 28px;
  border-radius: 50%;
  background: var(--bg3); border: 1px solid var(--border2);
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 700; color: var(--text3);
  flex-shrink: 0;
  transition: all .3s;
}
.step-label { font-size: 13px; color: var(--text3); font-weight: 500; transition: color .3s; white-space: nowrap; }
.progress-step.active .step-num { background: #fff; color: #000; border-color: #fff; }
.progress-step.active .step-label { color: var(--text); }
.progress-step.done .step-num { background: var(--success); border-color: var(--success); color: #000; }
.progress-step.done .step-label { color: var(--text2); }
.progress-line {
  flex: 1; height: 1px;
  background: var(--border);
  margin: 0 12px;
  transition: background .3s;
}
.progress-line.done { background: var(--success); }

/* ─── LAYOUT ─── */
.checkout-layout {
  max-width: 1060px;
  margin: 0 auto;
  padding: 36px 24px 60px;
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 28px;
  align-items: start;
}

/* ─── CARD ─── */
.card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  animation: fadeUp .4s ease both;
}
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}
.card + .card { margin-top: 20px; }

.card-header {
  padding: 20px 24px;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
}
.card-title {
  font-family: 'Syne', sans-serif;
  font-size: 16px; font-weight: 700; color: var(--text);
  display: flex; align-items: center; gap: 10px;
}
.card-title-num {
  width: 24px; height: 24px;
  background: var(--bg3); border: 1px solid var(--border2);
  border-radius: 50%;
  font-size: 11px; font-weight: 700; color: var(--text2);
  display: flex; align-items: center; justify-content: center;
}
.card-body { padding: 24px; }

/* ─── LOGGED-IN BANNER ─── */
.logged-banner {
  display: flex; align-items: center; gap: 12px;
  background: rgba(68,221,136,.06);
  border: 1px solid rgba(68,221,136,.2);
  border-radius: var(--radius-sm);
  padding: 12px 16px;
  margin-bottom: 20px;
  font-size: 13px; color: var(--text2);
}
.logged-banner svg { color: var(--success); flex-shrink: 0; }
.logged-banner strong { color: var(--text); }

/* ─── FORM ─── */
.form-row {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 14px; margin-bottom: 14px;
}
.form-row.single { grid-template-columns: 1fr; }
.form-group { display: flex; flex-direction: column; gap: 6px; }
.form-label {
  font-size: 11px; font-weight: 600;
  letter-spacing: 1px; text-transform: uppercase;
  color: var(--text3);
}
.form-label .req { color: var(--danger); margin-left: 2px; }

.input-wrap { position: relative; }
.form-input {
  width: 100%;
  background: var(--bg3); border: 1px solid var(--border2);
  color: var(--text); font-family: inherit; font-size: 14px;
  border-radius: var(--radius-sm);
  padding: 12px 14px;
  outline: none;
  transition: border-color .2s, background .2s, box-shadow .2s;
}
.form-input:focus {
  border-color: #666;
  box-shadow: 0 0 0 3px rgba(255,255,255,.04);
}
.form-input::placeholder { color: var(--text3); }
.form-input:disabled {
  background: var(--bg3);
  color: var(--text2);
  cursor: not-allowed;
  opacity: .75;
  border-color: var(--border);
}
.form-input.error { border-color: var(--danger); }
.form-input.success { border-color: var(--success); }

.input-icon {
  position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
  color: var(--text3); display: flex; align-items: center;
  pointer-events: none;
}
.input-icon.clickable { pointer-events: all; cursor: pointer; }
.input-icon.clickable:hover { color: var(--text2); }

.form-hint { font-size: 11px; color: var(--text3); margin-top: 4px; }
.form-error { font-size: 11px; color: var(--danger); margin-top: 4px; display: none; }
.form-error.show { display: block; }

.locked-badge {
  display: inline-flex; align-items: center; gap: 4px;
  background: var(--bg4); border: 1px solid var(--border);
  color: var(--text3); font-size: 10px; font-weight: 600;
  letter-spacing: .5px; text-transform: uppercase;
  padding: 3px 8px; border-radius: 999px;
}

/* ─── PASSWORD STRENGTH ─── */
.strength-bar {
  display: flex; gap: 4px; margin-top: 6px;
}
.strength-seg {
  flex: 1; height: 3px;
  background: var(--border2);
  border-radius: 999px;
  transition: background .3s;
}
.strength-seg.weak   { background: var(--danger); }
.strength-seg.medium { background: #f5a623; }
.strength-seg.strong { background: var(--success); }
.strength-label { font-size: 11px; color: var(--text3); margin-top: 4px; }

/* ─── PAYMENT METHOD ─── */
.payment-methods {
  display: grid; grid-template-columns: repeat(3,1fr);
  gap: 10px; margin-bottom: 20px;
}
.pm-btn {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; gap: 8px;
  background: var(--bg3); border: 1px solid var(--border2);
  border-radius: var(--radius); padding: 16px 10px;
  cursor: pointer; transition: all .2s;
  font-family: inherit;
}
.pm-btn:hover { border-color: var(--border3); background: var(--bg4); }
.pm-btn.selected {
  background: rgba(255,255,255,.06);
  border-color: #fff;
  box-shadow: 0 0 0 1px #fff inset;
}
.pm-icon { font-size: 24px; line-height: 1; }
.pm-label {
  font-size: 12px; font-weight: 600; color: var(--text2);
  transition: color .2s;
}
.pm-btn.selected .pm-label { color: var(--text); }

/* ─── PAYMENT SUB OPTIONS ─── */
.payment-sub {
  display: none;
  animation: fadeUp .25s ease;
}
.payment-sub.show { display: block; }

.sub-title {
  font-size: 11px; font-weight: 600; letter-spacing: 1px;
  text-transform: uppercase; color: var(--text3);
  margin-bottom: 10px;
}
.sub-options { display: flex; flex-wrap: wrap; gap: 8px; }

.sub-option {
  display: flex; align-items: center; gap: 10px;
  background: var(--bg3); border: 1px solid var(--border2);
  border-radius: var(--radius-sm); padding: 10px 14px;
  cursor: pointer; transition: all .15s;
  min-width: 130px;
}
.sub-option:hover { border-color: var(--border3); }
.sub-option.selected {
  border-color: #fff;
  background: rgba(255,255,255,.05);
}
.sub-option input[type="radio"] { display: none; }
.sub-opt-emoji { font-size: 20px; line-height: 1; }
.sub-opt-text { }
.sub-opt-name { font-size: 13px; font-weight: 600; color: var(--text); }
.sub-opt-desc { font-size: 11px; color: var(--text3); }
.sub-option .check-ring {
  width: 16px; height: 16px;
  border: 1.5px solid var(--border2);
  border-radius: 50%; margin-left: auto;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; transition: all .15s;
}
.sub-option.selected .check-ring {
  border-color: #fff; background: #fff;
}
.sub-option.selected .check-ring::after {
  content: '';
  width: 6px; height: 6px;
  background: #000; border-radius: 50%;
}

/* ─── DIVIDER ─── */
.section-divider {
  height: 1px; background: var(--border);
  margin: 24px 0;
}

/* ─── ORDER SUMMARY (RIGHT COLUMN) ─── */
.summary-card { position: sticky; top: calc(var(--navbar-h) + 20px); }

.order-items { }
.order-item {
  display: flex; align-items: center; gap: 14px;
  padding: 14px 0;
  border-bottom: 1px solid var(--border);
}
.order-item:last-child { border-bottom: none; }
.order-item-icon {
  width: 44px; height: 44px;
  background: var(--bg3); border: 1px solid var(--border2);
  border-radius: var(--radius-sm);
  display: flex; align-items: center; justify-content: center;
  font-size: 20px; flex-shrink: 0;
}
.order-item-info { flex: 1; min-width: 0; }
.order-item-name {
  font-size: 13px; font-weight: 600; color: var(--text);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  margin-bottom: 2px;
}
.order-item-cat { font-size: 11px; color: var(--text3); text-transform: uppercase; letter-spacing: .5px; }
.order-item-price { font-size: 14px; font-weight: 700; color: var(--text); flex-shrink: 0; font-family: 'Syne', sans-serif; }

.price-rows { margin: 4px 0 16px; }
.price-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 8px 0;
  font-size: 14px;
}
.price-row:not(:last-child) { border-bottom: 1px solid var(--border); }
.price-row .label { color: var(--text2); }
.price-row .value { color: var(--text); font-weight: 500; }
.price-row.discount .value { color: var(--success); }
.price-row.total {
  font-family: 'Syne', sans-serif;
  font-size: 18px; font-weight: 800;
  border-top: 1px solid var(--border2) !important;
  padding-top: 16px; margin-top: 4px;
}
.price-row.total .label { color: var(--text); }
.price-row.total .value { color: var(--text); }

.promo-wrap {
  display: flex; gap: 8px; margin: 16px 0;
}
.promo-input {
  flex: 1;
  background: var(--bg3); border: 1px solid var(--border2);
  color: var(--text); font-family: inherit; font-size: 13px;
  border-radius: var(--radius-sm); padding: 10px 14px;
  outline: none; transition: border-color .2s;
}
.promo-input:focus { border-color: #555; }
.promo-input::placeholder { color: var(--text3); }
.btn-promo {
  background: var(--bg3); border: 1px solid var(--border2);
  color: var(--text2); font-family: inherit; font-size: 13px; font-weight: 600;
  border-radius: var(--radius-sm); padding: 10px 16px;
  cursor: pointer; transition: all .15s;
  white-space: nowrap;
}
.btn-promo:hover { border-color: #555; color: var(--text); }
.promo-success {
  display: none; align-items: center; gap: 6px;
  font-size: 12px; color: var(--success); margin-top: 4px;
}
.promo-success.show { display: flex; }

/* ─── SUBMIT BUTTON ─── */
.btn-place-order {
  width: 100%;
  padding: 16px;
  background: #fff; color: #000;
  border: none; border-radius: 999px;
  font-family: 'Syne', sans-serif;
  font-size: 16px; font-weight: 800;
  cursor: pointer; letter-spacing: -.3px;
  position: relative; overflow: hidden;
  transition: opacity .15s, transform .15s;
  display: flex; align-items: center; justify-content: center; gap: 10px;
}
.btn-place-order:hover { opacity: .9; transform: translateY(-1px); }
.btn-place-order:active { transform: scale(.98); }
.btn-place-order:disabled { opacity: .4; cursor: not-allowed; transform: none; }

.btn-place-order .spinner {
  width: 18px; height: 18px;
  border: 2.5px solid rgba(0,0,0,.2);
  border-top-color: #000;
  border-radius: 50%;
  animation: spin .7s linear infinite;
  display: none;
}
.btn-place-order.loading .btn-text { opacity: 0; }
.btn-place-order.loading .spinner { display: block; position: absolute; }

@keyframes spin { to { transform: rotate(360deg); } }

.secure-note {
  display: flex; align-items: center; justify-content: center; gap: 6px;
  font-size: 12px; color: var(--text3);
  margin-top: 12px; text-align: center;
}

/* ─── SUCCESS STATE ─── */
.success-overlay {
  display: none;
  position: fixed; inset: 0;
  background: rgba(0,0,0,.85);
  backdrop-filter: blur(12px);
  z-index: 999;
  align-items: center; justify-content: center;
}
.success-overlay.show { display: flex; }
.success-box {
  background: var(--bg2); border: 1px solid var(--border2);
  border-radius: 24px; padding: 48px 40px;
  max-width: 440px; width: 90%;
  text-align: center;
  animation: fadeUp .4s ease;
}
.success-icon {
  width: 72px; height: 72px;
  background: rgba(68,221,136,.12);
  border: 1px solid rgba(68,221,136,.3);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 20px;
  font-size: 30px;
}
.success-title {
  font-family: 'Syne', sans-serif;
  font-size: 26px; font-weight: 800;
  color: var(--text); margin-bottom: 8px;
}
.success-subtitle { font-size: 14px; color: var(--text2); margin-bottom: 28px; line-height: 1.7; }
.success-order-id {
  background: var(--bg3); border: 1px solid var(--border2);
  border-radius: var(--radius-sm); padding: 12px 20px;
  font-size: 13px; color: var(--text2);
  margin-bottom: 28px;
}
.success-order-id span {
  font-family: 'Syne', sans-serif;
  font-size: 15px; font-weight: 700; color: var(--text);
  display: block; margin-top: 4px;
}

/* ─── REQUEST BODY PREVIEW ─── */
.req-body-wrap {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  overflow: hidden;
  margin-top: 20px;
}
.req-body-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 10px 16px;
  border-bottom: 1px solid var(--border);
  background: var(--bg2);
}
.req-body-title { font-size: 11px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--text3); }
.req-method { font-size: 11px; font-weight: 700; color: var(--success); }
.req-body-pre {
  padding: 14px 16px;
  font-family: 'Courier New', monospace;
  font-size: 11px; line-height: 1.7; color: var(--text2);
  overflow-x: auto;
  max-height: 280px; overflow-y: auto;
  white-space: pre;
}
.json-key { color: #7dd3fc; }
.json-str { color: #86efac; }
.json-num { color: #fda4af; }
.json-bool { color: #c4b5fd; }
.json-null { color: var(--text3); }

/* ─── TOAST ─── */
.toast-container {
  position: fixed; bottom: 24px; left: 50%;
  transform: translateX(-50%);
  z-index: 9999;
  display: flex; flex-direction: column; gap: 8px;
  align-items: center; pointer-events: none;
}
.toast {
  background: var(--bg2); border: 1px solid var(--border2);
  color: var(--text); font-size: 14px;
  padding: 10px 20px; border-radius: 999px;
  box-shadow: var(--shadow);
  display: flex; align-items: center; gap: 8px;
  animation: toastIn .3s ease; pointer-events: all;
}
@keyframes toastIn {
  from { opacity: 0; transform: translateY(12px) scale(.95); }
  to   { opacity: 1; transform: none; }
}
.toast.hide { animation: toastOut .3s ease forwards; }
@keyframes toastOut { to { opacity: 0; transform: translateY(8px) scale(.95); } }

/* ─── RESPONSIVE ─── */
@media (max-width: 820px) {
  .checkout-layout {
    grid-template-columns: 1fr;
    padding: 20px 16px 48px;
  }
  .summary-card { position: static; order: -1; }
  .progress-steps { gap: 0; }
  .step-label { display: none; }
  .navbar { padding: 0 16px; }
}
@media (max-width: 480px) {
  .form-row { grid-template-columns: 1fr; }
  .payment-methods { grid-template-columns: repeat(3,1fr); gap: 8px; }
  .pm-btn { padding: 14px 6px; }
  .pm-icon { font-size: 20px; }
  .pm-label { font-size: 11px; }
  .sub-options { }
  .sub-option { min-width: 0; flex: 1; }
  .progress-wrap { padding: 0 16px; }
  .card-body { padding: 18px; }
  .success-box { padding: 32px 24px; }
}
</style>
</head>
<body>

<!-- ═══════ NAVBAR ═══════ -->
<nav class="navbar">
  <button class="nav-back" onclick="history.back()">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="15 18 9 12 15 6"/>
    </svg>
    Kembali
  </button>

  <a href="index.html" class="nav-brand">DIGI<span>STORE</span></a>
  <div class="nav-spacer"></div>
  <div class="nav-secure">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
      <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
      <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
    </svg>
    Pembayaran Aman
  </div>
</nav>

<!-- ═══════ PROGRESS ═══════ -->
<div class="progress-wrap">
  <div class="progress-steps">
    <div class="progress-step done" id="step1">
      <div class="step-num">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <span class="step-label">Keranjang</span>
    </div>
    <div class="progress-line done"></div>
    <div class="progress-step active" id="step2">
      <div class="step-num">2</div>
      <span class="step-label">Checkout</span>
    </div>
    <div class="progress-line"></div>
    <div class="progress-step" id="step3">
      <div class="step-num">3</div>
      <span class="step-label">Konfirmasi</span>
    </div>
  </div>
</div>

<!-- ═══════ MAIN LAYOUT ═══════ -->
<div class="checkout-layout">

  <!-- ══════ LEFT: FORM ══════ -->
  <div class="form-col">

    <!-- SECTION 1: INFO -->
    <div class="card" style="animation-delay:.05s">
      <div class="card-header">
        <div class="card-title">
          <div class="card-title-num">1</div>
          Informasi Akun
        </div>
        <div id="loginStatusBadge"></div>
      </div>
      <div class="card-body">

        <!-- Logged-in banner -->
        <div class="logged-banner" id="loggedBanner" style="display:none">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          <span>Login sebagai <strong id="loggedName"></strong>. Data Anda terisi otomatis.</span>
        </div>

        <!-- Name Row -->
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Nama Depan <span class="req">*</span></label>
            <div class="input-wrap">
              <input type="text" class="form-input" id="firstName" placeholder="John" autocomplete="given-name">
              <div class="input-icon" id="firstNameLock" style="display:none">
