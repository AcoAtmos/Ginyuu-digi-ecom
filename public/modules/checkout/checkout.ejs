<!-- ═══════ TOAST ═══════ -->
<div class="toast-container" id="toastContainer"></div>

<script>
// ════════════════════════════════════════════════
// SIMULATE: data dari landing page (cart + user)
// ════════════════════════════════════════════════
const CART_ITEMS = [
  { id: 3, name: 'Full-Stack Web Dev 2025', category: 'course', emoji: '💻', price: 299000 },
  { id: 5, name: 'Framer Landing Page Kit', category: 'template', emoji: '🚀', price: 199000 },
  { id: 6, name: 'AI Prompt Engineering', category: 'ebook', emoji: '🤖', price: 59000 },
];

// Simulasi user login state — ubah ke null untuk guest mode
// null = guest | { name, email } = logged in
let CURRENT_USER = null;
/* Contoh logged-in:
let CURRENT_USER = { name: 'Budi Santoso', email: 'budi@example.com' };
*/

// ════════════════════════════════════════════════
// STATE
// ════════════════════════════════════════════════
let selectedPayment = null;
let selectedSub = null;
let promoApplied = false;
let promoDiscount = 0;

// ════════════════════════════════════════════════
// INIT
// ════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded', () => {
  renderOrderSummary();
  initUserState();
  updateReqBody();

  // Live req body update on any input
  document.querySelectorAll('.form-input').forEach(inp => {
    inp.addEventListener('input', updateReqBody);
  });
});

// ════════════════════════════════════════════════
// USER STATE
// ════════════════════════════════════════════════
function initUserState() {
  const pwSection = document.getElementById('passwordSection');
  const loggedBanner = document.getElementById('loggedBanner');
  const loginStatusBadge = document.getElementById('loginStatusBadge');
  const loggedName = document.getElementById('loggedName');

  const fields = ['firstName','lastName','email'];
  const locks  = ['firstNameLock','lastNameLock','emailLock'];

  if (CURRENT_USER) {
    // — LOGGED IN —
    const parts = CURRENT_USER.name.trim().split(' ');
    const first = parts[0];
    const last  = parts.slice(1).join(' ') || '-';

    document.getElementById('firstName').value = first;
    document.getElementById('lastName').value  = last;
    document.getElementById('email').value     = CURRENT_USER.email;

    // Disable & lock fields
    fields.forEach((f, i) => {
      const el = document.getElementById(f);
      el.disabled = true;
      el.classList.add('success');
      document.getElementById(locks[i]).style.display = 'flex';
    });

    // Hide password section
    pwSection.style.display = 'none';

    // Show banner
    loggedBanner.style.display = 'flex';
    loggedName.textContent = CURRENT_USER.name;

    // Badge
    loginStatusBadge.innerHTML = `<span class="locked-badge">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
      Terisi otomatis
    </span>`;

  } else {
    // — GUEST —
    pwSection.style.display = '';
    loggedBanner.style.display = 'none';

    loginStatusBadge.innerHTML = `<span class="locked-badge" style="color:var(--text3);border-color:var(--border)">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
      </svg>
      Tamu
    </span>`;
  }

  updateReqBody();
}

// Toggle user state (untuk demo / testing)
function toggleLoginDemo() {
  if (CURRENT_USER) {
    CURRENT_USER = null;
  } else {
    CURRENT_USER = { name: 'Budi Santoso', email: 'budi@example.com' };
  }
  // Reset inputs
  ['firstName','lastName','email'].forEach(f => {
    const el = document.getElementById(f);
    el.value = '';
    el.disabled = false;
    el.classList.remove('success');
  });
  ['firstNameLock','lastNameLock','emailLock'].forEach(id => {
    document.getElementById(id).style.display = 'none';
  });
  initUserState();
  showToast(CURRENT_USER ? `👋 Login sebagai ${CURRENT_USER.name}` : '👤 Mode tamu aktif');
}

// ════════════════════════════════════════════════
// ORDER SUMMARY
// ════════════════════════════════════════════════
function renderOrderSummary() {
  const container = document.getElementById('orderItems');
  const countEl   = document.getElementById('itemCount');
  countEl.textContent = `${CART_ITEMS.length} produk`;

  container.innerHTML = CART_ITEMS.map(item => `
    <div class="order-item">
      <div class="order-item-icon">${item.emoji}</div>
      <div class="order-item-info">
        <div class="order-item-name">${item.name}</div>
        <div class="order-item-cat">${item.category}</div>
      </div>
      <div class="order-item-price">${formatRp(item.price)}</div>
    </div>`).join('');

  renderPriceRows();
}

function renderPriceRows() {
  const subtotal  = CART_ITEMS.reduce((s, i) => s + i.price, 0);
  const adminFee  = 2000;
  const discount  = promoApplied ? Math.round(subtotal * 0.2) : 0;
  const total     = subtotal + adminFee - discount;

  document.getElementById('priceRows').innerHTML = `
    <div class="price-row">
      <span class="label">Subtotal</span>
      <span class="value">${formatRp(subtotal)}</span>
    </div>
    <div class="price-row">
      <span class="label">Biaya Admin</span>
      <span class="value">${formatRp(adminFee)}</span>
    </div>
    ${discount ? `<div class="price-row discount">
      <span class="label">Diskon Promo</span>
      <span class="value">- ${formatRp(discount)}</span>
    </div>` : ''}
    <div class="price-row total">
      <span class="label">Total</span>
      <span class="value">${formatRp(total)}</span>
    </div>`;
}

// ════════════════════════════════════════════════
// PAYMENT
// ════════════════════════════════════════════════
function selectPayment(method) {
  selectedPayment = method;
  selectedSub = null;

  // Update button UI
  document.querySelectorAll('.pm-btn').forEach((b, i) => {
    const methods = ['bank','ewallet','qris'];
    b.classList.toggle('selected', methods[i] === method);
  });

  // Show/hide sub panels
  ['bank','ewallet','qris'].forEach(m => {
    const el = document.getElementById('sub-' + m);
    el.classList.toggle('show', m === method);
    if (m !== method) {
      // Clear selection
      el.querySelectorAll('.sub-option').forEach(o => o.classList.remove('selected'));
    }
  });

  // Clear sub if qris (no sub needed)
  if (method === 'qris') selectedSub = 'QRIS';

  document.getElementById('paymentErr').style.display = 'none';
  updateReqBody();
}

function selectSub(el, value) {
  selectedSub = value;
  const container = el.closest('.sub-options');
  container.querySelectorAll('.sub-option').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  updateReqBody();
}

// ════════════════════════════════════════════════
// PROMO
// ════════════════════════════════════════════════
const VALID_PROMOS = ['DIGI20', 'DIGISTORE', 'HEMAT20'];

function applyPromo() {
  const val = document.getElementById('promoInput').value.toUpperCase().trim();
  const successEl = document.getElementById('promoSuccess');

  if (VALID_PROMOS.includes(val)) {
    promoApplied = true;
    successEl.classList.add('show');
    showToast('🎉 Kode promo berhasil diterapkan!');
  } else {
    promoApplied = false;
    successEl.classList.remove('show');
    if (val) showToast('❌ Kode promo tidak valid');
  }
  renderPriceRows();
  updateReqBody();
}

// ════════════════════════════════════════════════
// VALIDATION
// ════════════════════════════════════════════════
function validateForm() {
  let valid = true;

  const fName = document.getElementById('firstName').value.trim();
  const lName = document.getElementById('lastName').value.trim();
  const email = document.getElementById('email').value.trim();

  showErr('firstNameErr',  !fName);
  showErr('lastNameErr',   !lName);
  showErr('emailErr',      !validateEmail(email));

  if (!fName || !lName || !validateEmail(email)) valid = false;

  if (!CURRENT_USER) {
    const pass    = document.getElementById('password').value;
    const confirm = document.getElementById('confirmPassword').value;
    showErr('passwordErr',        pass.length < 8);
    showErr('confirmPasswordErr', pass !== confirm || !confirm);
    if (pass.length < 8 || pass !== confirm) valid = false;
  }

  if (!selectedPayment) {
    document.getElementById('paymentErr').style.display = 'block';
    valid = false;
  }

  if ((selectedPayment === 'bank' || selectedPayment === 'ewallet') && !selectedSub) {
    showToast('⚠️ Pilih bank atau e-wallet Anda');
    valid = false;
  }

  return valid;
}

function showErr(id, show) {
  const el = document.getElementById(id);
  if (el) el.classList.toggle('show', show);
}

function validateEmail(e) {
  return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e);
}

// ════════════════════════════════════════════════
// REQUEST BODY
// ════════════════════════════════════════════════
function buildRequestBody() {
  const subtotal = CART_ITEMS.reduce((s, i) => s + i.price, 0);
  const adminFee = 2000;
  const discount = promoApplied ? Math.round(subtotal * 0.2) : 0;
  const total    = subtotal + adminFee - discount;

  const body = {
    customer: {
      first_name:     document.getElementById('firstName').value.trim() || null,
      last_name:      document.getElementById('lastName').value.trim()  || null,
      email:          document.getElementById('email').value.trim()     || null,
      is_registered:  !!CURRENT_USER,
    },
    order: {
      items: CART_ITEMS.map(i => ({
        product_id:   i.id,
        product_name: i.name,
        category:     i.category,
        price:        i.price,
        qty:          1,
      })),
      subtotal,
      admin_fee:   adminFee,
      discount,
      total,
      promo_code:  promoApplied ? document.getElementById('promoInput').value.toUpperCase().trim() : null,
    },
    payment: {
      method:     selectedPayment || null,
      provider:   selectedSub     || null,
    },
    meta: {
      source:     'web',
      timestamp:  new Date().toISOString(),
      user_agent: navigator.userAgent.substring(0, 60) + '...',
    },
  };

  // Kalau guest, sertakan password (hashed di backend)
  if (!CURRENT_USER) {
    body.customer.password        = document.getElementById('password').value ? '••••••••' : null;
    body.customer.confirm_password = document.getElementById('confirmPassword').value ? '••••••••' : null;
  }

  return body;
}

function updateReqBody() {
  const body = buildRequestBody();
  document.getElementById('reqBodyPre').innerHTML = syntaxHighlight(JSON.stringify(body, null, 2));
}

function syntaxHighlight(json) {
  return json
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(
      /("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g,
      (match) => {
        let cls = 'json-num';
        if (/^"/.test(match)) {
          cls = /:$/.test(match) ? 'json-key' : 'json-str';
        } else if (/true|false/.test(match)) {
          cls = 'json-bool';
        } else if (/null/.test(match)) {
          cls = 'json-null';
        }
        return `<span class="${cls}">${match}</span>`;
      }
    );
}

// ════════════════════════════════════════════════
// SUBMIT
// ════════════════════════════════════════════════
function submitOrder() {
  if (!validateForm()) {
    showToast('⚠️ Mohon lengkapi data terlebih dahulu');
    // Scroll to first error
    const firstErr = document.querySelector('.form-error.show, .form-input.error');
    if (firstErr) firstErr.scrollIntoView({ behavior: 'smooth', block: 'center' });
    return;
  }

  const btn = document.getElementById('placeOrderBtn');
  btn.disabled = true;
  btn.classList.add('loading');

  const reqBody = buildRequestBody();

  // Simulate API call
  console.log('📦 Request Body sent to backend:', JSON.stringify(reqBody, null, 2));

  setTimeout(() => {
    btn.classList.remove('loading');
    btn.disabled = false;

    const orderId = '#DS-' + Math.random().toString(36).substr(2,6).toUpperCase();
    document.getElementById('orderIdDisplay').textContent = orderId;
    document.getElementById('successOverlay').classList.add('show');

    // Mark progress step done
    document.getElementById('step2').className = 'progress-step done';
    document.getElementById('step2').querySelector('.step-num').innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>`;
    document.getElementById('step3').className = 'progress-step active';
    document.querySelector('.progress-line:last-of-type').classList.add('done');

  }, 1800);
}

// ════════════════════════════════════════════════
// PASSWORD STRENGTH
// ════════════════════════════════════════════════
function checkStrength(val) {
  const segs  = [1,2,3,4].map(n => document.getElementById('seg' + n));
  const label = document.getElementById('strengthLabel');
  let score = 0;
  if (val.length >= 8)                      score++;
  if (/[A-Z]/.test(val))                    score++;
  if (/[0-9]/.test(val))                    score++;
  if (/[^A-Za-z0-9]/.test(val))             score++;

  const cls   = score <= 1 ? 'weak' : score <= 2 ? 'medium' : 'strong';
  const label_ = score === 0 ? '' : score <= 1 ? '🔴 Lemah' : score <= 2 ? '🟡 Sedang' : score <= 3 ? '🟢 Kuat' : '🟢 Sangat Kuat';

  segs.forEach((s, i) => {
    s.className = 'strength-seg';
    if (i < score) s.classList.add(cls);
  });
  label.textContent = label_;
  updateReqBody();
}

// ════════════════════════════════════════════════
// TOGGLE PASSWORD VISIBILITY
// ════════════════════════════════════════════════
function togglePass(inputId, iconWrap) {
  const input = document.getElementById(inputId);
  const isPass = input.type === 'password';
  input.type = isPass ? 'text' : 'password';
  iconWrap.innerHTML = isPass
    ? `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>`
    : `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`;
}

