            <a href="/page/register" id="mobileRegisterLink">Register</a>
            <a href="/page/profile" id="mobileProfileLink" style="display:none;">My Profile</a>
            <a href="#" id="mobileLogoutLink" style="display:none;">Logout</a>
        </nav>
    </div>
</div>

<!-- Profile Dropdown Menu - Default for logged out users -->
<template id="profileMenuTemplateLoggedOut">
    <a href="/page/login">Login</a>
    <a href="/page/register">Register</a>
</template>
<template id="profileMenuTemplateLoggedIn">
    <a href="/page/profile">My Profile</a>
    <a href="#orders">My Orders</a>
    <div class="divider"></div>
    <a href="#" id="logoutBtn">Logout</a>
</template>

<style>
/* ============================================
   LAYOUT & NAVBAR STYLES
   ============================================ */

