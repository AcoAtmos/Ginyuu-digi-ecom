<!-- ============================================
     UNIFIED NAVBAR - Used across all pages
     ============================================ -->

<header class="main-header">
    <div class="header-container">
        <!-- Logo -->
        <a href="/page/home" class="logo">GINYUU</a>

        <!-- Navigation (desktop) -->
        <nav class="main-nav">
            <a href="/page/home" class="nav-link">Home</a>
            <a href="/page/browsAll" class="nav-link">Products</a>
            <a href="#categories" class="nav-link">Categories</a>
            <a href="#reviews" class="nav-link">Reviews</a>
        </nav>

        <!-- Actions -->
        <div class="header-actions">
            <!-- Search -->
            <div class="search-wrapper">
                <input type="text" id="headerSearch" placeholder="Search products..." class="search-input">
                <button class="search-btn" title="Search">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="8"/>
                        <path d="m21 21-4.35-4.35"/>
                    </svg>
                </button>
            </div>

            <!-- Cart -->
            <button class="icon-btn cart-btn" title="Cart">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 4h1.5L9 16m0 0h8m-8 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4Zm8 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4Zm-8.5-3h9.25L19 7H7.312"/>
                </svg>
