<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — Ginyuu Admin</title>
  <link rel="stylesheet" href="/assets/css/admin.css">
</head>
<body>
  <div class="auth-page">
    <div class="auth-card">
      <div class="auth-logo">
        <h1>GINYUU</h1>
        <p>Admin Panel</p>
      </div>
      <div class="auth-form">
        <div class="auth-title">Sign in</div>
        <div class="auth-error" id="authError"></div>
        <form id="loginForm">
          <div class="form-group">
            <label class="form-label">Email</label>
            <input class="form-input" type="email" name="email" placeholder="admin@ginyuu.com" required autocomplete="email">
          </div>
          <div class="form-group">
            <label class="form-label">Password</label>
            <input class="form-input" type="password" name="password" placeholder="••••••••" required autocomplete="current-password">
          </div>
          <button class="btn btn-primary" type="submit" style="width:100%;padding:14px;font-size:15px;margin-top:4px">Sign in</button>
        </form>
        <div class="auth-divider"></div>
        <div class="auth-footer"><a href="/auth/forget-password">Forgot password?</a></div>
      </div>
    </div>
  </div>
  <script src="/assets/js/main.js"></script>
  <script src="/assets/js/auth.js"></script>
</body>
</html>
