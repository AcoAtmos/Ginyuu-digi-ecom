<%- include('../layouts/admin-layout', { title: 'Change Password', page: 'profile' }) %>

<div class="section-card" style="max-width:520px">
  <div class="section-card-header">
    <div class="section-card-title">Change Password</div>
  </div>
  <div class="section-card-body" style="padding:24px">
    <div class="auth-error" id="formError" style="display:none"></div>
    <div class="auth-error" id="formSuccess" style="display:none;background:rgba(52,211,153,0.1);border-color:rgba(52,211,153,0.2);color:#4ade80"></div>
    <form id="changePasswordForm">
      <div class="form-group">
        <label class="form-label">Current Password</label>
        <input class="form-input" type="password" name="current_password" required>
      </div>
      <div class="form-group">
        <label class="form-label">New Password</label>
        <input class="form-input" type="password" name="new_password" required minlength="6">
      </div>
      <div class="form-group">
        <label class="form-label">Confirm New Password</label>
        <input class="form-input" type="password" name="confirm" required>
      </div>
      <div class="form-actions" style="border-top:none;padding-top:0;margin-top:0">
        <a href="/profile" class="btn btn-ghost">Cancel</a>
        <button class="btn btn-primary" type="submit">Update password</button>
      </div>
    </form>
  </div>
</div>

<%- include('../layouts/admin-footer') %>
<script>
document.getElementById('changePasswordForm')?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const form = e.target;
  const btn = form.querySelector('button[type="submit"]');
  const errEl = document.getElementById('formError');
  const sucEl = document.getElementById('formSuccess');
  const data = Object.fromEntries(new FormData(form));
  errEl.style.display = 'none';
  sucEl.style.display = 'none';
  if (data.new_password !== data.confirm) {
    errEl.textContent = 'Passwords do not match';
    errEl.style.display = 'block';
    return;
  }
  btn.disabled = true;
  btn.textContent = 'Updating...';
  try {
    const res = await fetch('/api/profile/change-password', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ current_password: data.current_password, new_password: data.new_password }),
    });
    const result = await res.json();
    if (result.success) {
      sucEl.textContent = 'Password changed successfully';
      sucEl.style.display = 'block';
      form.reset();
    } else {
      errEl.textContent = result.message;
      errEl.style.display = 'block';
    }
  } catch {
    errEl.textContent = 'Connection error';
    errEl.style.display = 'block';
  } finally {
    btn.disabled = false;
    btn.textContent = 'Update password';
  }
});
</script>
