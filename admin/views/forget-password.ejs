<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Password — Ginyuu Admin</title>
  <link rel="stylesheet" href="/assets/css/admin.css">
</head>
<body>
  <div class="auth-page">
    <div class="auth-card">
      <div class="auth-logo">
        <h1>GINYUU</h1>
        <p>Admin Panel</p>
      </div>
      <div class="auth-form">
        <div class="auth-title">Reset password</div>
        <p style="color:#666;font-size:14px;text-align:center;margin-bottom:24px">Enter your email and we'll send you a reset link</p>
        <div class="auth-error" id="authError"></div>
        <form id="forgotForm">
          <div class="form-group">
            <label class="form-label">Email</label>
            <input class="form-input" type="email" name="email" placeholder="admin@ginyuu.com" required>
          </div>
          <button class="btn btn-primary" type="submit" style="width:100%;padding:14px;font-size:15px">Send reset link</button>
        </form>
        <div class="auth-divider"></div>
        <div class="auth-footer"><a href="/auth/login">Back to sign in</a></div>
      </div>
    </div>
  </div>
  <script src="/assets/js/main.js"></script>
  <script src="/assets/js/auth.js"></script>
</body>
</html>
