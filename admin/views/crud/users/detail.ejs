<%- include('../../layouts/admin-layout', { title: 'User Detail', page: 'users' }) %>

<div class="detail-grid" id="userDetail">
  <div class="loader" style="grid-column:1/-1"><div class="loader-spinner"></div></div>
</div>

<%- include('../../layouts/admin-footer') %>
<script>
(async function() {
  const id = window.location.pathname.split('/').pop();
  try {
    const res = await fetch(`/api/admin/users/detail/${id}`);
    const data = await res.json();
    if (!data.success) { document.querySelector('.detail-grid').innerHTML = '<p style="color:#666;text-align:center;padding:48px">User not found</p>'; return; }
    const u = data.data;
    document.getElementById('userDetail').innerHTML = `
      <div class="detail-section">
        <div class="detail-section-title">Account Info</div>
        <div class="detail-row"><span class="detail-label">ID</span><span class="detail-value">${u.id}</span></div>
        <div class="detail-row"><span class="detail-label">Username</span><span class="detail-value">${u.username}</span></div>
        <div class="detail-row"><span class="detail-label">Email</span><span class="detail-value">${u.email}</span></div>
        <div class="detail-row"><span class="detail-label">Phone</span><span class="detail-value">${u.phone || '—'}</span></div>
        <div class="detail-row"><span class="detail-label">Role</span><span class="detail-value">${statusBadge(u.role)}</span></div>
        <div class="detail-row"><span class="detail-label">Status</span><span class="detail-value">${statusBadge(u.status)}</span></div>
        <div class="detail-row"><span class="detail-label">Total Orders</span><span class="detail-value">${u.total_orders || 0}</span></div>
        <div class="detail-row"><span class="detail-label">Joined</span><span class="detail-value">${formatDate(u.created_at)}</span></div>
      </div>
      <div class="detail-section" style="display:flex;flex-direction:column;gap:12px;justify-content:center">
        <a href="/admin/users/edit/${u.id}" class="btn btn-secondary" style="justify-content:center">Edit user</a>
        <button class="btn btn-danger" style="justify-content:center" onclick="deleteUser(${u.id})">Delete user</button>
        <button class="btn btn-ghost" style="justify-content:center" onclick="resetPassword(${u.id})">Reset password</button>
      </div>
    `;
  } catch(e) { document.querySelector('.detail-grid').innerHTML = '<p style="color:#666;text-align:center;padding:48px">Error loading user</p>'; }
})();

async function deleteUser(id) {
  if (!confirm('Delete this user? This cannot be undone.')) return;
  try {
    const res = await fetch(`/api/admin/users/delete/${id}`, { method: 'DELETE' });
    const data = await res.json();
    if (data.success) { showToast('User deleted'); setTimeout(() => window.location.href = '/admin/users', 1000); }
    else showToast(data.message, 'error');
  } catch { showToast('Delete failed', 'error'); }
}

async function resetPassword(id) {
  const pwd = prompt('Enter new password (min 6 chars):', 'Admin123!');
  if (!pwd) return;
  try {
    const res = await fetch(`/api/admin/users/reset-password/${id}`, { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({new_password: pwd}) });
    const data = await res.json();
    if (data.success) showToast('Password reset successfully');
    else showToast(data.message, 'error');
  } catch { showToast('Reset failed', 'error'); }
}
</script>
